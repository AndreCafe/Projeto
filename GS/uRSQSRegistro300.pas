  aData: TDateTime; aCaixa, aURLs, aQtdSessoes: Integer; aTempoSessoes: Double;
  aRes, aSearch: String): Boolean;
var 
  Achou : Boolean; 
  SL : TStrings; 
  I: Integer;
  aCodLoja : Integer;
  cTipo : Char;
  sEng: String;
begin
  InitTran(nxDB, [tCli, tEst, tEstSearch, tEstRes], True);
  try
    tEstSearch.IndexName := 'IEstEng';
    Reg.Conta := aConta;
    if Reg.CodLoja>0 then
      aCodLoja := Reg.CodLoja
    else 
    if (Trim(aConta)>'') and tCli.Locate('EmailConta', aConta, [loCaseInsensitive]) then
      aCodLoja := tCli.FieldByName('Codigo').AsInteger else
      aCodLoja := 0;
      
    if aCodLoja>0 then begin
      tEst.IndexName := 'ILojaCaixa';
      Achou := tEst.FindKey([aCodLoja, aCaixa]);
    end else begin
      tEst.IndexName := 'ICodEquipCaixa';
      Achou := tEst.FindKey([aCodEquip, aCaixa]);
    end;
    if Achou then begin
      while tEstSearch.FindKey([tEstID.Value]) do tEstSearch.Delete;
      if aCodLoja>0 then begin
        tEstRes.IndexName := 'ILojaRes';
        while tEstRes.FindKey([aCodLoja]) do tEstRes.Delete;
      end else begin
        tEstRes.IndexName := 'ICodEquipRes';
        while tEstRes.FindKey([aCodEquip]) do tEstRes.Delete;
      end;
      tEst.Edit;
    end else 
      tEst.Insert;
    tEstLoja.Value := aCodLoja;
    tEstCodEquip.Value := aCodEquip;
    tEstData.Value := aData;
    tEstCaixa.Value := aCaixa;
    tEstURLs.Value := aURLs;
    tEstSessoesQtd.Value := aQtdSessoes;
    tEstSessoesTempo.Value := aTempoSessoes;  
    tEstDataAtu.Value := Now;
    tEst.Post;
    SL := TStringList.Create;
    try
      SL.Text := aRes;
      for I := 0 to SL.Count - 1 do begin
        tEstRes.Insert;
        tEstResLoja.Value := aCodLoja;
        tEstResCodEquip.Value := aCodEquip;
        tEstResRes.Value := SL.Names[I];
        tEstResQtd.Value := StrToIntDef(SL.ValueFromIndex[I], 0);
        tEstRes.Post;
      end;
  
      SL.Text := aSearch;
      for I := 0 to SL.Count - 1 do begin
        sEng := SL.Names[I];
        if sEng>'' then
          cTipo := sEng[1] else
          cTipo := #0;
        Delete(sEng, 1, 2);
        
        if (sEng>'') and (cTipo<>#0) then begin
          if tEstSearch.FindKey([tEstID.Value, sEng]) then
            tEstSearch.Edit else
            tEstSearch.Insert;
          tEstSearchEng.Value := sEng;
          tEstSearchLoja.Value := aCodLoja;
          tEstSearchCodEquip.Value := aCodEquip;
          tEstSearchData.Value := aData;
          tEstSearchCaixa.Value := aCaixa;
          tEstSearchEst.Value := tEstID.Value;
          tEstSearchDataAtu.Value := tEstDataAtu.Value;
          case cTipo of
            'q' : tEstSearchQtd.Value := StrToIntDef(SL.ValueFromIndex[I], 0);
            'p' : tEstSearchPag.Value := StrToIntDef(SL.ValueFromIndex[I], 0);
          end;
          tEstSearch.Post;
        end;
      end;
    finally
      SL.Free;
    end;
    nxDB.Commit;
  except
    nxDB.Rollback;
    Raise;
  end;
  Result := True;
end;

procedure TransfDados(O, D: TDataset; Tudo: Boolean);
var 
  I : Integer;
  F : TField;
begin
  for I := 0 to D.FieldCount-1 do with D.Fields[I] do 
  if Tudo or ((DataType<>ftAutoInc) and (Pos('|'+UpperCase(FieldName)+'|', CamposReadOnly)=0)) then 
  begin
    F := O.FindField(FieldName);
    if F<>nil then
      Value := F.Value;
  end;  
end;

function TqsRegistro300.CriarConta(
  const Args: array of Variant): Variant;
var 
  SIndex : String;
  SLE : TStrings;
  S : String;
  Dia : TDateTime;
  A, B: TCabAutorizacao;
  I: Integer;
  SL: TStringList;
begin
  Result := VarArrayOf(['Atualize o seu NexCafé baixando a ultima versăo do site www.nexcafe.com.br. Năo é possível utilizar essa versăo antiga']);
  Exit;
  A := TCabAutorizacao.Create;
  B := TCabAutorizacao.Create;
  SL := TStringList.Create;
  try
    SL.Text := Args[0];
    tCli.IndexName := 'IEmailConta';
    if tCli.FindKey([SL.Values['Email']]) then begin
      Result := VarArrayOf(['Já existe uma conta com o e-mail "' + SL.Values['Email'] + 
                            '". É necessário um e-mail diferente para cada loja.']);         
      Exit;
    end;     
      
    tCli.Active := False;
    tCli.Active := True;
    tCli.Insert;
    tCli.FieldByName('Loja').AsString := Sl.Values['Nome'];
    tCli.FieldByname('Proprietario').AsString := Sl.Values['Prop'];
    tCli.FieldByName('Pais').AsString := Sl.Values['Pais'];
    tCli.FieldByName('Cidade').AsString := sl.Values['Cidade'];
    tCli.FieldByName('UF').AsString := sl.Values['UF'];
    tCli.FieldByName('CodEquip').AsString := SL.Values['CodEquip'];
    tCli.FieldByName('EmailReg').AsString := SL.Values['Email'];
    tCli.FieldByName('EmailConta').AsString := SL.Values['Email'];
    tCli.FieldByName('LicMaq').AsInteger := 1;
    tCli.FieldByName('Senha').AsString := sl.Values['Senha'];
    tCli.FieldByName('CadastroEm').AsDateTime := Now;
    tCli.FieldByName('CadastroPor').AsString := 'Cliente';
    tCli.FieldByName('AtualizadoEm').AsDateTime := Now;
    tCli.FieldByName('AtualizadoPor').AsString := 'Cliente';
    tCli.FieldByName('Programa').AsInteger := 1;
    tCli.FieldByName('Ativado').AsBoolean := False;
    tCli.FieldByName('CodAtivacao').AsString := GeraCodAtivacao;
    tCli.Post;
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
    Reg.CodLoja := LI.liLoja;
    A.Load(tCli.FieldByName('Codigo').AsInteger, tCli, tAut);
    B.AssignFrom(A);
    with A.NewItem do begin
      auTipo := taFreePremium;
      auMaquinas := 1;
      auVencimento := 0;
    end;
    A.Save('cliente', B, tCli, tAut, True);
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
    LI.liHD := A.caCodEquip;
    tAut.IndexName := 'ILoja';
    if not tAut.FindKey([ LI.liLoja, True]) then
      Result := VarArrayOf(['Falha no servidor de contas Nextar. Por favor faça contato através da opçăo de atendimento online do nosso site: www.nexcafe.com.br']) else
      Result := VarArrayOf(['OK', SL.Values['Email'], ChaveAtivar]);
    SLE := TStringList.Create;
    try
      tCorpo.Active := True;
      S := ExtractFilePath(ParamStr(0)) + 'emailativacao.txt';
      if FileExists(S) then begin
        SLE.LoadFromFile(S);
        S := SLE.Text;

        repeat
          I := Pos('%EMAIL', S);
          if I>0 then
            S := Copy(S, 1, I-1) + tCli.FieldByName('EmailConta').AsString + Copy(S, I+6, Length(S));
        until (I<1);

        repeat
          I := Pos('%PROPRIETARIO', S);
          if I>0 then
            S := Copy(S, 1, I-1) + Sl.Values['Prop'] + Copy(S, I+13, Length(S));
        until (I<1);

        repeat
          I := Pos('%CODATIVACAO', S);
          if I>0 then
            S := Copy(S, 1, I-1) + tCli.FieldByName('CodAtivacao').AsString + Copy(S, I+12, Length(S));
        until (I<1);

        S := S + sLineBreak + sLineBreak + sLineBreak + 
             'Controle: ' + GetMD5Str(tCli.FieldByName('EmailConta').AsString+'nextar'+tCli.FieldByName('Codigo').AsString);
        
        tCorpo.Insert;
        tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
        tCorpoInclusao.Value := Now;
        tCorpoProcessou.Value := False;
        tCorpoDestino.Value := tCli.FieldByName('EmailConta').AsString;
        tCorpoAssunto.Value := 'NexCafé: Código de Ativaçăo ' + tCli.FieldByName('CodAtivacao').AsString;
        tCorpoCorpo.Value := S;
        tCorpo.Post;
        SLE.Clear;
      end;
      
      tCorpo.Insert;
      tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
      tCorpoInclusao.Value := Now;
      tCorpoProcessou.Value := False;
      tCorpoDestino.Value := TodosNextar;
      tCorpoAssunto.Value := 'NexCafé - Nova Conta!';
      SLE.Add('Conta criada em ' + FormatDateTime('dd/mm/yyyy hh:mm', Now));
      SLE.Add('');
      SLE.Add('Loja = ' + tCli.FieldByName('Loja').AsString);
      SLE.Add('Código = ' + CodLojaToStr(tCli.FieldByName('Codigo').AsInteger));
      SLE.Add('Código de Equipamento = ' + tCli.FieldByName('CodEquip').AsString);
      SLE.Add('Proprietario = ' + tCli.FieldByName('Proprietario').AsString);
      SLE.Add('Cidade = ' + tCli.FieldByName('Cidade').AsString + '/' + tCli.FieldByName('UF').AsString);
      SLE.Add('');
      SLE.Add('Email = ' + tCli.FieldByname('EmailConta').AsString);
      SLE.Add('Senha = ' + tCli.FieldByName('Senha').AsString);
      SLE.Add('Código de Ativaçăo = ' + tCli.FieldByName('CodAtivacao').AsString);
      tCorpoCorpo.Value := SLE.Text;
      tCorpo.Post;
    except
    end;
    SLE.Free;
    tCorpo.Active := False;
  finally
    SL.Free;
    A.Free;
    B.Free;
  end;    
end;

function TqsRegistro300.ObtemSenha(const Args: array of Variant): Variant;
begin
  Reg.Conta := Args[0];

  tCli.Active := False;
  tCli.Active := True;
  if Reg.CodLoja>0 then begin
    tCli.IndexName := 'ICodigo';
    tCli.SetRange([Args[0]], [Args[0]]);
  end else begin
    tCli.IndexName := 'IEmailConta';
    tCli.SetRange([Reg.Conta], [Reg.Conta]);
  end;
  try
    try
      if not tCli.IsEmpty then
        Result := EnviaEmailRegistros(tCli);
        
      if Result='' then
        Result := VarArrayOf(['']) else
        Result := VarArrayOf(['OK', Result]); 
    finally
      tCli.CancelRange;
    end;
  finally
    tCli.IndexName := 'ICodigo';
  end;
end;

procedure TqsRegistro300.OpenDB(aForce: Boolean);
begin
  if (nxSession.ServerEngine=nil) or aForce then begin
    Start_DBConn(nxSession, aForce);
    nxDB.Active := False;
    nxDB.AliasPath := '';
    nxDB.AliasName := 'Registro';
  end;

  if aForce then begin
    tCli.Active := False;
    tPrecos.Active := False;
    tCorpo.Active := False;
    tLog.Active := False;
    tAut.Active := False;
    tEst.Active := False;
    tEstSearch.Active := False;
    tEstRes.Active := False;
    tIPLoja.Active := False;
    tRec.Active := False;
    nxDB.Active := False;
  end;

  if (not tCli.Active) then begin
    nxDB.Open;
    tCorpo.Active := True;
    tPrecos.Active := True;
    tCli.Open;
    tLog.Open;
    tAut.Open;
    tEst.Open;
    tEstSearch.Open;
    tEstRes.Open;
    tIPLoja.Open;
    tRec.Open;
  end;
end;

function TqsRegistro300.CancelarBoleto(const Args: array of Variant): Variant;
var N: TDateTime;
begin  
  tCli.Active := False;
  tCli.Active := True;
  tRec.Active := False;
  tRec.Active := True;
  Reg.Conta := Args[0];
  LI.liDetalhes.Add('Conta = ' + Args[0]);
  LI.liDetalhes.Add('Senha = '  +Args[1]);
  LI.liLoja := 0;
  tCli.IndexName := 'IEmailConta';
  if (Reg.CodLoja=0) and not tCli.FindKey([Reg.Conta]) then
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  tCli.IndexName := 'ICodigo';
  if (Reg.CodLoja>0) and not tCli.FindKey([Reg.CodLoja]) then
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  
  if (not SameText(tCli.FieldByName('Senha').AsString, Args[1])) then
  begin
    Result := VarArrayOf(['Senha incorreta']);
    Exit;
  end;

  if not tRec.Locate('ID', Args[2], []) then begin
    Result := VarArrayOf(['Boleto năo encontrado']);
    Exit;
  end;

  if tRecCancelado.Value then begin
    Result := VarArrayOf(['Esse boleto já foi cancelado em ' + FormatDateTime('dd/mm/yyyy', tRecCanceladoEm.Value)]);
    Exit;
  end;

  if tRecLoja.Value <> LI.liLoja then begin
    Result := VarArrayOf(['Esse boleto é de outra loja']);
    Exit;
  end;

  N := Now;
  
  tRec.Edit;
  tRecCancelado.Value := True;
  tRecCanceladoEm.Value := N;
  tRecCanceladoPor.Value := 'cliente';
  tRecPagamento.Value := N;
  tRecBaixou.Value := True;
  tRec.Post;

  Result := VarArrayOf(['OK', N]);
end;

function TqsRegistro300.ChecaConta(
  const Args: array of Variant): Variant;
    {Conta: String; Versao: String; SerieHD: String; EmDemo: Boolean}
var 
  S: String;  
  AutID : Integer;
begin
  AutID := 0;
  tCli.Active := False;
  tCli.Active := True;
  tAut.Active := True;
  Reg.Conta := Args[0];

  tCli.IndexName := 'IEmailConta';

  if Reg.CodLoja>0 then
    LI.liLoja := Reg.CodLoja
  else 
  if tCli.FindKey([Trim(Reg.Conta)]) then begin
    Reg.Conta := Trim(Reg.Conta);
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  end else
    LI.liLoja := 0;    
  
  LI.liOper := opChecaConta;
    
  LI.liDetalhes.Add('Versăo NexServ = ' + Args[1]); 

  tAut.IndexName := 'ILoja'; 

  tCli.IndexName := 'ICodigo';

  if LI.liLoja>0 then begin
    if (not tCli.FindKey([LI.liLoja])) then begin
      try DebugMsg('TqsRegistro300.ChecaConta - LJ NAO Encontrada - Conta: '+Args[0]+' - LI.LiLoja: '+IntToStr(LI.liLoja)); except end;
      Result := VarArrayOf(['OK', Reg.Conta, ChaveInexistente, '']);
      Exit;
    end;
  
    if (tCli.FieldByName('Bloqueado').AsBoolean=True) 
    then begin
      DebugMsg('* BLOQUEADO = TRUE - Loja = ' + IntToStr(LI.liLoja) + ' - Conta: ' + Reg.Conta);
      Result := VarArrayOf(['OK', Reg.Conta, ChaveBloqueado, '']);
    end else
    if (not tAut.FindKey([LI.liLoja, True])) then begin
      DebugMsg('* NAO ACHOU AUT - Loja = ' + IntToStr(LI.liLoja) + ' - Conta: ' + Reg.Conta);
      Exit;
    end else  
    if tCli.FieldByName('Programa').AsInteger=0 then
      Result := VarArrayOf(['OK', Args[0], ChaveCybermgr, ''])
    else
    if not tCli.FieldByname('Ativado').AsBoolean then
      Result := VarArrayOf(['OK', Reg.Conta, ChaveAtivar, ''])
    else begin
      S := '';
      tAut.IndexName := 'ILoja';
      tAut.SetRange([LI.liLoja, True], [LI.liLoja, True]);
      try
        while not tAut.Eof do begin
          if S>'' then S := S + ';';
          S := S + tAut.FieldByName('Autorizacao').AsString;
          if not tAut.FieldByName('EnviouCli').AsBoolean then 
            AutID := tAut.FieldByName('ID').AsInteger;
          tAut.Next;
        end;
      finally
        tAut.CancelRange;
      end;
      
      ccInfo_Add(Trim(Args[1]), LI.liIP, tCliCodigo.Value, Args[2], AutID, False);
      
      Result := VarArrayOf(['OK', Args[0], S, ObtemBP(LI.liLoja), ObtemJFP(LI.liLoja)]);
    end ;
  end else
    Result := VarArrayOf(['OK', 0, ChaveInexistente, 0, False]);
end;

procedure TqsRegistro300.CheckDB;
begin
  try
    try
      OpenDB(False);
      tCli.Refresh;
    except
       OpenDB(True);
    end;
  except
  end;
end;

function TqsRegistro300.TrocaHD(const Args: array of Variant): Variant;
var 
  A, B : TCabAutorizacao;
  S: String;
  aLoja: Integer;
begin
  tCli.Active := False;
  tCli.Active := True;
  Reg.Conta := Trim(Args[0]);
  LI.liLoja := Reg.CodLoja;

  tCli.IndexName := 'IEmailConta';
  if (Reg.CodLoja=0) and not tCli.FindKey([Reg.Conta]) then begin
    Result := 'Conta inexistente';
    Exit;
  end;

  tCli.IndexName := 'ICodigo';
  if (Reg.CodLoja>0) and not tCli.FindKey([Reg.CodLoja]) then
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;
  
  if tCli.FieldByName('Senha').AsString<>Args[1] then begin
    Result := VarArrayOf(['Senha incorreta']);
    Exit;
  end;
  
  if tCli.FieldByName('Programa').AsInteger<>1 then begin
    Result := VarArrayOf(['Conta inválida para uso no NexCafé']);
    Exit;
  end;
  
  DebugMsg('TqsRegistro300.TrocaHD - Loja: '+tCli.FieldByName('Codigo').AsString);
  
  LI.liLoja :=   tCli.FieldByName('Codigo').AsInteger;
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  LI.liDetalhes.Add('Serial HD anterior = ' + tCli.FieldByName('SerieHD').AsString);
  LI.liHD := Args[2];
  A := TCabAutorizacao.Create;
  B := TCabAutorizacao.Create;
  try
    A.Load(LI.liLoja, tCli , tAut);
    B.AssignFrom(A);
    A.caCodEquip := LI.liHD;
    A.Save('cliente', B, tCli, tAut, True);
    S := '';
    tAut.IndexName := 'ILoja';
    tAut.SetRange([LI.liLoja, True], [LI.liLoja, True]);
    try
      while not tAut.Eof do begin
        if S>'' then S := S + ';';
        S := S + tAut.FieldByName('Autorizacao').AsString;
        if not tAut.FieldByName('EnviouCli').AsBoolean then begin
          tAut.Edit;
          tAut.FieldByName('EnviouCli').AsBoolean := True;
          tAut.Post;
        end;
        tAut.Next;
      end;
    finally
      tAut.CancelRange;
    end;
    Result := VarArrayOf(['OK', Args[0], S, ObtemBP(LI.liLoja), ObtemJFP(LI.liLoja)]);
  finally
    A.Free;
    B.Free;
  end;
end;

function TqsRegistro300.TrocaProg(const Args: array of Variant): Variant;
var 
  A, B : TCabAutorizacao;
  S: String;
begin
  Result := VarArrayOf(['É necessário baixar a versăo atual do NexCafé em www.nexcafe.com.br']);
  Exit;

  
  tCli.Active := False;
  tCli.Active := True;
  LI.liLoja :=   Args[0];
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  tCli.IndexName := 'ICodigo';
  if (not tCli.FindKey([Trim(Args[0])])) then 
    Result := VarArrayOf(['Loja năo cadastrada na Nextar'])
  else
  if tCli.FieldByName('Senha').AsString<>Args[1] then
    Result := VarArrayOf(['A senha de registro da loja năo está correta'])
  else 
  if tCli.FieldByName('Programa').AsInteger=1 then
    Result := VarArrayOf(['Licença já foi transferida para o NexCafé'])
  else begin
    LI.liDetalhes.Add('Serial HD anterior = ' + tCli.FieldByName('SerieHD').AsString);
    LI.liHD := Args[2];
    A := TCabAutorizacao.Create;
    B := TCabAutorizacao.Create;
    try
      A.Load(LI.liLoja, tCli , tAut);
      B.AssignFrom(A);
      A.caCodEquip := LI.liHD;
      A.caPrograma := 1;
      A.Save('cliente', B, tCli, tAut, True);
      S := '';
      tAut.IndexName := 'ILoja';
      tAut.SetRange([LI.liLoja, True], [LI.liLoja, True]);
      try
        while not tAut.Eof do begin
          if S>'' then S := S + ';';
          S := S + tAut.FieldByName('Autorizacao').AsString;
          if not tAut.FieldByName('EnviouCli').AsBoolean then begin
            tAut.Edit;
            tAut.FieldByName('EnviouCli').AsBoolean := True;
            tAut.Post;
          end;
          tAut.Next;
        end;
      finally
        tAut.CancelRange;
      end;
      Result := VarArrayOf(['OK', LI.liLoja, S, 0, False]);
    finally
      A.Free;
      B.Free;
    end;
  end;  
end;

function TqsRegistro300.AlterarSenha(const Args: array of Variant): Variant;
begin
  tCli.Active := False;
  tCli.Active := True;
  Reg.Conta := Trim(Args[0]);
  LI.liLoja := Reg.CodLoja;
  LI.liDetalhes.Add('Conta = ' + Args[0]);
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  LI.liDetalhes.Add('Nova Senha = ' + Args[2]);
  

  tCli.IndexName := 'IEmailConta';
  if (Reg.CodLoja=0) and not tCli.FindKey([Reg.Conta]) then 
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  tCli.IndexName := 'ICodigo';

  if (Reg.CodLoja>0) and not tCli.FindKey([Reg.CodLoja]) then 
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  
  if (not SameText(tCli.FieldByName('Senha').AsString, Args[1])) then
  begin
    Result := VarArrayOf(['Senha atual está incorreta']);
    Exit;
  end;
  
  InitTran(nxDb, [tCli], True);
  try
    tCli.Edit;
    tCli.FieldByName('Senha').AsString := Args[2];
    tCli.Post;
    nxDB.Commit;
  finally
    if nxDB.InTransaction then nxDB.Rollback;
  end;

  Result := VarArrayOf(['OK']);
end;

function TqsRegistro300.Assinar(const Args: array of Variant): Variant;
var 
  SL, SL2 : TStringList;
  S, ArqBol : String;
  B : TDadosBoleto;
  D : TDadosEmissaoBol;
  I : Integer;
  Venc : TDateTime;
begin
  Raise Exception.Create('Utilize o site http://assinar.nextar.com.br para emitir o boleto de assinatura');
  tCli.Active := False;
  tCli.Active := True;
  Reg.Conta := Trim(Args[0]);
  LI.liLoja := 0;
  LI.liOper := opAssinar;
  LI.liDetalhes.Add('Conta = ' + Reg.Conta);
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  tCli.IndexName := 'IEmailConta';
  if not tCli.FindKey([Reg.Conta]) then begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;
  LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  if not SameText(tCli.FieldByName('Senha').AsString, Args[1]) then begin
    Result := VarArrayOf(['Senha Incorreta']);
    Exit;
  end;
  tPrecos.IndexName := 'IMeses';
  if not tPrecos.FindKey([tCliCodDesc.Value, Args[2]]) then begin
    Result := VarArrayOf(['Tipo de assinatura inválido']);
    Exit;
  end;
  
  SL := TStringList.Create;  SL2 := TStringList.Create;
  try
    InitTran(nxDB, [tCli, tRec, tCorpo], True);
    try
      SL.Text := Args[3];
      tCli.Edit;
      tCli.FieldByName('RazaoSocial').AsString := SL.Values['RazaoSocial'];
      tCli.FieldByName('CNPJ').AsString := SL.Values['CNPJ'];
      tCli.FieldByName('IE').AsString := SL.Values['IE'];
      tCli.FieldByName('Endereco').AsString := SL.Values['Endereco'];
      tCli.FieldByName('Cidade').AsString := SL.Values['Cidade'];
      tCli.FieldByName('UF').AsString := SL.Values['UF'];
      tCli.FieldByName('CEP').AsString := SL.Values['CEP'];
      tCli.FieldByName('Bairro').AsString := SL.Values['Bairro'];
      tCli.FieldByName('Tel1').AsString := SL.Values['Tel1'];
      tCli.FieldByName('Tel2').AsString := SL.Values['Tel2'];
      tCli.FieldByName('Tel3').AsString := SL.Values['Tel3'];
      tCli.FieldByName('Tel4').AsString := SL.Values['Tel4'];
      tCli.Post;

      tRec.Append;
      tRec.FieldByName('Premium').AsBoolean := True;
      tRec.FieldByName('Loja').AsInteger := LI.liLoja;
      Venc := Date;
      if DayOfWeek(Venc) = 1 then
        Venc := Date + 1
      else
      if DayOfWeek(Venc)=7 then
        Venc := Date + 2;
      
      Venc := Venc + 1;
      tRec.FieldByName('Vencimento').AsDateTime := Venc;
      tRec.FieldByName('Lancamento').AsDateTime := Now;
      tRec.FieldByName('Valor').AsCurrency := tPrecos.FieldByName('Valor').AsCurrency;
      tRec.FieldByName('Premium').AsBoolean := True;
      tRec.FieldByName('ClienteLancou').AsBoolean := True;
      tRec.FieldByName('PremiumDias').AsInteger := tPrecos.FieldByName('Meses').AsInteger * 30;
      tRec.FieldByName('Descricao').AsString := tPrecos.FieldByName('Descr').AsString;
      tRec.Post;

      tRec.Edit;
      FB.Vencimento := Venc;
      FB.DataDocumento := tRec.FieldByName('Lancamento').AsDateTime;
      FB.Valor := tRec.FieldByName('Valor').AsCurrency;
      FB.NossoNumero := tRec.FieldByName('ID').AsString;
      FB.Documento := tRec.FieldByName('ID').AsString;
      FB.Instrucoes.Text := tPrecos.FieldByName('Descr').AsString;

      FB.Sacado.Nome := SL.Values['RazaoSocial'];
      if Length(ApenasDig(SL.Values['CNPJ']))>11 then
        FB.Sacado.Pessoa := pJuridica else
        FB.Sacado.Pessoa := pFisica;
      FB.Sacado.CNPJ_CPF := ApenasDig(SL.Values['CNPJ']);  
      FB.Sacado.Endereco := SL.Values['Endereco'];
      FB.Sacado.Estado := SL.Values['UF'];
      FB.Sacado.Cidade := SL.Values['Cidade'];
      FB.Sacado.Cep  := SL.Values['CEP'];
      FB.Sacado.Bairro := SL.Values['Bairro'];
      FB.Preparar;

      ArqBol := 'Boleto'+tRec.FieldByName('ID').AsString+'.jpg';
      
      FBI.SaveBoletoImagem(ArqBol, 0);
      tRec.FieldByName('Doc').Value := FB.DadosGerados.LinhaDigitavel;
      tRec.Post;

      B.dbVenc := FB.Vencimento;
      B.dbLanc := FB.DataDocumento;
      B.dbNum := tRecID.AsInteger;
      B.dbValor := FB.Valor;
      B.dbDescr := FB.Instrucoes.Text;
      B.dbPagoEm := 0;
      B.dbCanceladoEm := 0;
      
      D.deNome := SL.Values['RazaoSocial'];
      D.deCNPJ  := SL.Values['CNPJ'];
      D.deEnd := SL.Values['Endereco'];
      D.deCidade := SL.Values['Cidade'];
      D.deUF := SL.Values['UF'];
      D.deCedente := FB.Cedente.Nome;

      try
        tCorpo.Active := True;
        S := ExtractFilePath(ParamStr(0)) + 'email_assinatura.txt';
        if FileExists(S) then begin
          SL.LoadFromFile(S);
          S := SL.Text;
  
          repeat
            I := Pos('%NOMEASS', S);
            if I>0 then
              S := Copy(S, 1, I-1) + tPrecos.FieldByName('Descr').AsString + Copy(S, I+8, Length(S));
          until (I<1);
  
          repeat
            I := Pos('%VENCIMENTO', S);
            if I>0 then
              S := Copy(S, 1, I-1) + FormatDateTime('dd/mm/yyyy', B.dbVenc) + Copy(S, I+11, Length(S));
          until (I<1);
  
          repeat
            I := Pos('%ID', S);
            if I>0 then
              S := Copy(S, 1, I-1) + tRec.FieldByName('ID').AsString + Copy(S, I+3, Length(S));
          until (I<1);
          
          repeat
            I := Pos('%NUMBOLETO', S);
            if I>0 then
              S := Copy(S, 1, I-1) + tRec.FieldByName('Doc').AsString + Copy(S, I+10, Length(S));
          until (I<1);
  
          repeat
            I := Pos('%VALOR', S);
            if I>0 then
              S := Copy(S, 1, I-1) + FloatToStrF(B.dbValor, ffCurrency, 10, 2) + Copy(S, I+6, Length(S));
          until (I<1);
          
          tCorpo.Insert;
          tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
          tCorpoInclusao.Value := Now;
          tCorpoProcessou.Value := False;
          tCorpoDestino.Value := tCli.FieldByName('EmailConta').AsString;
          tCorpoAssunto.Value := 'NexCafé - Boleto de Assinatura';
          tCorpoCorpo.Value := S;
          tCorpoAnexos.Value := 'boleto.jpg='+ArqBol;
          tCorpo.Post;
  
        end;
        SL.Text := Args[3];
        
        SL.Insert(0, 'Conta = ' + Args[0]);
        SL.Insert(1, 'Num.Pedido = '  + tRec.FieldByName('ID').AsString);
        SL.Insert(2, 'Valor = ' + tPrecos.FieldByName('Valor').AsString);
        SL.Insert(3, tPrecos.FieldByName('Descr').AsString);
        SL.Insert(4, '');

        tCorpo.Insert;
        tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
        tCorpoInclusao.Value := Now;
        tCorpoProcessou.Value := False;
        tCorpoDestino.Value := TodosNextar;
        tCorpoAssunto.Value := 'NexCafé - ' + tPrecos.FieldByName('Descr').AsString;
        tCorpoCorpo.Value := SL.Text;
        tCorpoAnexos.Value := 'boleto.jpg='+ArqBol;
        tCorpo.Post;
      except
      end;
      nxDB.Commit;
      
      Result := VarArrayOf(['OK', DadosEmissaoBolToVariant(D), BoletoToVariant(B)]);
    finally
      if nxDB.InTransaction then nxDB.Rollback;
    end;
  finally
    SL.Free;
    SL2.Free;
  end;
  
end;

function TqsRegistro300.Ativar(const Args: array of Variant): Variant;
var 
  A, B : TCabAutorizacao;
  S: String;
begin
  tCli.Active := False;
  tCli.Active := True;
  Reg.Conta := Trim(Args[0]);
  LI.liDetalhes.Add('Código de Ativaçăo = ' + Args[1]);
  LI.liLoja := 0;
  LI.liOper := opAtivarConta;
  tCli.IndexName := 'IEmailConta';
  if not tCli.FindKey([Reg.Conta]) then begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;
  LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  if tCli.FieldByName('Ativado').AsBoolean then
    Result := VarArrayOf(['Essa conta já está ativada']) 
  else
  if not SameText(tCli.FieldByName('CodAtivacao').AsString, Args[1]) then
    Result := VarArrayOf(['Código de Ativaçăo informado está incorreto'])
  else begin
    S := '';
    InitTran(nxDB, [tCli], True);
    try
      tCli.Edit;
      tCli.FieldByName('Ativado').AsBoolean := True;
      tCli.FieldByName('AtivadoEm').AsDateTime := Now;
      tCli.Post;
      nxDB.Commit;
    finally
      if nxDB.InTransaction then nxDB.Rollback;
    end;
    tAut.IndexName := 'ILoja';
    tAut.SetRange([LI.liLoja, True], [LI.liLoja, True]);
    try
      while not tAut.Eof do begin
        if S>'' then S := S + ';';
        S := S + tAut.FieldByName('Autorizacao').AsString;
        if not tAut.FieldByName('EnviouCli').AsBoolean then begin
          tAut.Edit;
          tAut.FieldByName('EnviouCli').AsBoolean := True;
          tAut.Post;
        end;
        tAut.Next;
      end;
    finally
      tAut.CancelRange;
    end;
    Result := VarArrayOf(['OK', Reg.Conta, S, 0, False]);
  end;  
end;

