function TqsRegistro200.ProcessRequest(const Func: string;
  const ClientIdent: TkbmMWClientIdentity;
  const Args: array of Variant): Variant;
var 
  uFunc : String;  
begin
  Inc(nRequests[1]);

  uFunc := UpperCase(Func);
  try
    try
      tLog.Active := True;
    except
    end;  
    if uFunc='OBTEMLICENCATESTE' then begin
      LI.Inicia(opTesteGratis, ClientIdent.RemoteLocation);
      Result := ObtemLicencaTeste(Args);
    end else
    if uFunc='MODODEMO' then begin
      LI.Inicia(opModoDemo, ClientIdent.RemoteLocation);
      Result := LogModoDemo(Args);
    end else
    if uFunc='OBTEMREGISTRO' then begin
      LI.Inicia(opObtemLicenca, ClientIdent.RemoteLocation);
      Result := ObtemLicenca(Args);
    end else  
    if uFunc='TROCAHD' then begin
      LI.Inicia(opTrocaHD, ClientIdent.RemoteLocation);
      Result := TrocaHD(Args)
    end else  
    if uFunc='UPGRADENEX' then begin
      LI.Inicia(opUpgradeNex, ClientIdent.RemoteLocation);
      Result := TrocaProg(Args)
    end else  
    if uFunc='ATUALIZACADASTRO' then begin
      LI.Inicia(opAtualizaCadastro, ClientIdent.RemoteLocation);
      Result := AtualizaCadastro(Args);
    end else  
    if uFunc='OBTEMCADASTRO' then begin
      LI.Inicia(opObtemCadastro, ClientIdent.RemoteLocation);
      Result := ObtemCadastro(Args);
    end else 
    if uFunc='OBTEMCODLOJAPOREMAIL' then begin
      LI.Inicia(opObtemCodLojaPorEmail, ClientIdent.RemoteLocation);
      Result := ObtemCodLojaPorEmail(Args);
    end else
    if uFunc='OBTEMCODLOJAPOREQUIP' then begin
      LI.Inicia(opObtemCodLojaPorEquip, ClientIdent.RemoteLocation);
      Result := ObtemCodLojaPorEquip(Args);
    end else
    if uFunc='OBTEMSENHA' then begin
      LI.Inicia(opObtemSenha, ClientIdent.RemoteLocation);
      Result := ObtemSenha(Args);
    end else
    if uFunc='SALVAEST' then begin
      LI.Inicia(opSalvaEst, ClientIdent.RemoteLocation);
      Result := SalvaEst(Args);
    end else
      Result := inherited ProcessRequest(Func, ClientIdent, Args)
  except
    On E: Exception do
      Result := VarArrayOf(['Erro năo esperado no servidor de registro: ' + E.Message]);
  end;  
  try 
    if Result[0] = 'OK' then
      LI.liOK := True
    else begin 
      LI.liOK := False;
      LI.liDetalhes.Add('RESULTADO = ' + Result[0]);
    end;  
  except
  end;
  
  if not (LI.liOper in [opModoDemo, opObtemLicenca]) then
    LI.SaveToDataset(tLog);  
end;

function TqsRegistro200.SalvaEst(const Args: array of Variant): Variant;
begin
  Result := SalvaEstInt(Args[0], Args[1], Args[2], Args[3], Args[4], Args[5], Args[6], Args[7], Args[8]);
end;

function TqsRegistro200.SalvaEstInt(aCodLoja: Integer; aCodEquip: String;
  aData: TDateTime; aCaixa, aURLs, aQtdSessoes: Integer; aTempoSessoes: Double;
  aRes, aSearch: String): Boolean;
var 
  Achou : Boolean; 
  SL : TStrings; 
  I: Integer;
  cTipo : Char;
  sEng: String;
begin
  InitTran(nxDB, [tEst, tEstSearch, tEstRes], True);
  try
    tEstSearch.IndexName := 'IEstEng';
    if aCodLoja>0 then begin
      tEst.IndexName := 'ILojaCaixa';
      Achou := tEst.FindKey([aCodLoja, aCaixa]);
    end else begin
      tEst.IndexName := 'ICodEquipCaixa';
      Achou := tEst.FindKey([aCodEquip, aCaixa]);
    end;
    if Achou then begin
      while tEstSearch.FindKey([tEstID.Value]) do tEstSearch.Delete;
      if aCodLoja>0 then begin
        tEstRes.IndexName := 'ILojaRes';
        while tEstRes.FindKey([aCodLoja]) do tEstRes.Delete;
      end else begin
        tEstRes.IndexName := 'ICodEquipRes';
        while tEstRes.FindKey([aCodEquip]) do tEstRes.Delete;
      end;
      tEst.Edit;
    end else 
      tEst.Insert;
    tEstLoja.Value := aCodLoja;
    tEstCodEquip.Value := aCodEquip;
    tEstData.Value := aData;
    tEstCaixa.Value := aCaixa;
    tEstURLs.Value := aURLs;
    tEstSessoesQtd.Value := aQtdSessoes;
    tEstSessoesTempo.Value := aTempoSessoes;  
    tEstDataAtu.Value := Now;
    tEst.Post;
    SL := TStringList.Create;
    try
      SL.Text := aRes;
      for I := 0 to SL.Count - 1 do begin
        tEstRes.Insert;
        tEstResLoja.Value := aCodLoja;
        tEstResCodEquip.Value := aCodEquip;
        tEstResRes.Value := SL.Names[I];
        tEstResQtd.Value := StrToIntDef(SL.ValueFromIndex[I], 0);
        tEstRes.Post;
      end;
  
      SL.Text := aSearch;
      for I := 0 to SL.Count - 1 do begin
        sEng := SL.Names[I];
        if sEng>'' then
          cTipo := sEng[1] else
          cTipo := #0;
        Delete(sEng, 1, 2);
        
        if (sEng>'') and (cTipo<>#0) then begin
          if tEstSearch.FindKey([tEstID.Value, sEng]) then
            tEstSearch.Edit else
            tEstSearch.Insert;
          tEstSearchEng.Value := sEng;
          tEstSearchLoja.Value := aCodLoja;
          tEstSearchCodEquip.Value := aCodEquip;
          tEstSearchData.Value := aData;
          tEstSearchCaixa.Value := aCaixa;
          tEstSearchEst.Value := tEstID.Value;
          tEstSearchDataAtu.Value := tEstDataAtu.Value;
          case cTipo of
            'q' : tEstSearchQtd.Value := StrToIntDef(SL.ValueFromIndex[I], 0);
            'p' : tEstSearchPag.Value := StrToIntDef(SL.ValueFromIndex[I], 0);
          end;
          tEstSearch.Post;
        end;
      end;
    finally
      SL.Free;
    end;
    nxDB.Commit;
  except
    nxDB.Rollback;
    Raise;
  end;
  Result := True;
end;

procedure TransfDados(O, D: TDataset; Tudo: Boolean);
var 
  I : Integer;
  F : TField;
begin
  for I := 0 to D.FieldCount-1 do with D.Fields[I] do 
  if Tudo or ((DataType<>ftAutoInc) and (Pos('|'+UpperCase(FieldName)+'|', CamposReadOnly)=0)) then 
  begin
    F := O.FindField(FieldName);
    if F<>nil then
      Value := F.Value;
  end;  
end;

function TqsRegistro200.ObtemLicencaTeste(
  const Args: array of Variant): Variant;
var 
  SIndex : String;
  SLE : TStrings;
  S : String;
  Dia : TDateTime;
  A, B: TCabAutorizacao;
  I: Integer;
  SL: TStringList;
begin
  Result := VarArrayOf(['Para testar o NexCafé vocę deve baixar o NexCafé 4.0 do nosso site: www.nexcafe.com.br. O NexCafé 4.0 é grátis!']);
  Exit;
  
  A := TCabAutorizacao.Create;
  B := TCabAutorizacao.Create;
  SL := TStringList.Create;
  try
    SL.Text := Args[0];
    if tAut.Locate('CodigoEquip; Tipo', VarArrayOf([SL.Values['CodEquip'], taTesteGratuito]), []) then begin
      Result := VarArrayOf(['Já foi concedido anteriormente uma licença para teste para esse mesmo disco rígido. '+
                'Envie E-mail para vendas@nextar.com.br solicitando uma prorrogaçăo do seu período de teste gratuito.']);
      Exit;
    end;     
      
    tCli.Active := False;
    tCli.Active := True;
    tCli.Insert;
    tCli.FieldByName('Loja').AsString := Sl.Values['Nome'];
    tCli.FieldByname('Proprietarios').AsString := Sl.Values['Prop'];
    tCli.FieldByName('Telefones').AsString := Sl.Values['Tel'];
    tCli.FieldByName('Pais').AsString := Sl.Values['Pais'];
    tCli.FieldByName('Cidade').AsString := sl.Values['Cidade'];
    tCli.FieldByName('UF').AsString := sl.Values['Estado'];
    tCli.FieldByName('CEP').AsString := sl.Values['CEP'];
    tCli.FieldByName('Endereco').AsString := SL.Values['Endereco'];
    tCli.FieldByName('CodEquip').AsString := SL.Values['CodEquip'];
    tCli.FieldByName('EmailReg').AsString := SL.Values['Email'];
    tCli.FieldByName('Senha').AsString := sl.Values['Senha'];
    tCli.FieldByName('LicMaq').AsString := sl.Values['QtdMaq'];
    tCli.FieldByName('LicTipo').AsString := sl.Values['Tipo'];
    Dia := Date + 7;
    while DayOfWeek(Dia) in [1, 7] do Dia := Dia + 1;
    tCli.FieldByName('LicVenc').AsDateTime := Dia;
    tCli.FieldByName('CadastroEm').AsDateTime := Now;
    tCli.FieldByName('CadastroPor').AsString := 'Cliente';
    tCli.FieldByName('AtualizadoEm').AsDateTime := Now;
    tCli.FieldByName('AtualizadoPor').AsString := 'Cliente';
    if DayOfWeek(tCli.FieldByName('LicVenc').AsDateTime) = 1 then
      tCli.FieldByName('LicVenc').AsDateTime := tCli.FieldByName('LicVenc').Value + 1;
      
    if DayOfWeek(tCli.FieldByName('LicVenc').AsDateTime) = 7 then
      tCli.FieldByName('LicVenc').AsDateTime := tCli.FieldByName('LicVenc').AsDateTime + 2;
    tCli.FieldByName('Programa').AsInteger := 1;
    tCli.Post;
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
    Reg.CodLoja := LI.liLoja;
    A.Load(tCli.FieldByName('Codigo').AsInteger, tCli, tAut);
    B.AssignFrom(A);
    with A.NewItem do begin
      auTipo := taTesteGratuito;
      auMaquinas := tCli.FieldByName('LicMaq').AsInteger;
      auVencimento := Dia;
    end;
    A.Save('cliente', B, tCli, tAut);
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
    LI.liHD := A.caCodEquip;
    tAut.IndexName := 'ILoja';
    if not tAut.FindKey([ LI.liLoja, True]) then
      Result := VarArrayOf(['Falha no servidor de registro']) else
      Result := VarArrayOf(['OK', LI.liLoja, tAut.FieldByName('Autorizacao').AsString]);
    SLE := TStringList.Create;
    try
      tCorpo.Active := True;
      tCorpo.Insert;
      tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
      tCorpoInclusao.Value := Now;
      tCorpoProcessou.Value := False;
      tCorpoDestino.Value := Email_Cybermgr;
      tCorpoAssunto.Value := 'NexCafé - Novo Cadastro';
      SLE.Add('Nova loja testando o Nexcafé em ' + FormatDateTime('dd/mm/yyyy hh:mm', Now));
      SLE.Add('');
      SLE.Add('Loja = ' + tCli.FieldByName('Loja').AsString);
      SLE.Add('Código = ' + CodLojaToStr(tCli.FieldByName('Codigo').AsInteger));
      SLE.Add('Senha = ' + tCli.FieldByName('Senha').AsString);
      SLE.Add('Código de Equipamento = ' + tCli.FieldByName('CodEquip').AsString);
      SLE.Add('Maquinas = ' + tCli.FieldByName('LicMaq').AsString);
      SLE.Add('Proprietario = ' + tCli.FieldByName('Proprietarios').AsString);
      SLE.Add('Gerente = ' + tCli.FieldByName('Gerente').AsString);
      SLE.Add('Cidade = ' + tCli.FieldByName('Cidade').AsString + '/' + tCli.FieldByName('UF').AsString);
      SLE.Add('Telefones = ' + tCli.FieldByName('Telefones').AsString);
      SLE.Add('');
      SLE.Add('Email Registro = ' + tCli.FieldByname('EmailReg').AsString);
      SLE.Add('');
      SLE.Add('Email Técnico = ' + tCli.FieldByname('EmailTec').AsString);
      tCorpoCorpo.Value := SLE.Text;
      tCorpo.Post;

      S := ExtractFilePath(ParamStr(0)) + 'emailregnex.txt';
      if FileExists(S) then begin
        SLE.LoadFromFile(S);
        S := SLE.Text;

        repeat
          I := Pos('%CODLOJA', S);
          if I>0 then
            S := Copy(S, 1, I-1) + Reg.CodLojaAsString + Copy(S, I+8, Length(S));
        until (I<1);

        repeat
          I := Pos('%SENHAREG', S);
          if I>0 then
            S := Copy(S, 1, I-1) + tCli.FieldByName('Senha').AsString + Copy(S, I+9, Length(S));
        until (I<1);

        repeat
          I := Pos('%AUTORIZACAO', S);
          if I>0 then
          if Reg.NumChaves>0 then
            S := Copy(S, 1, I-1) + tAut.FieldByName('Autorizacao').AsString + Copy(S, I+12, Length(S)) else
            Delete(S, I, 12);
        until (I>1);
        
        tCorpo.Insert;
        tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
        tCorpoInclusao.Value := Now;
        tCorpoProcessou.Value := False;
        tCorpoDestino.Value := Trim(MT.FieldByName('EmailReg').AsString);
        tCorpoAssunto.Value := 'Registro NexCafé';
        tCorpoCorpo.Value := SLE.Text;
        tCorpo.Post;
      end;
    except
    end;
    SLE.Free;
    tCorpo.Active := False;
  finally
    SL.Free;
    A.Free;
    B.Free;
  end;    
end;

function TqsRegistro200.ObtemSenha(const Args: array of Variant): Variant;
