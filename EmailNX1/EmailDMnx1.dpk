{$DESCRIPTION 'Nextar - Email utils'}
{$RUNONLY}
{$IMPLICITBUILD OFF}

requires
  rtl,
  vcl,
  dbrtl,
  NexusDB108sd90,
  NexusDB108ll90,
  NexusDB108db90,
  NexusDB108sr90,
  NexusDB1081x90,
  NexusDB108st90,
  NexusDB108re90,
  NexusDB108tw90,
  NexusDB108ch90,
  IndyD2007;

contains
