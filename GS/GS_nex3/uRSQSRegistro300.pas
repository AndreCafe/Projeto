function TqsRegistro300.Assinar(const Args: array of Variant): Variant;
var 
  SL, SL2 : TStringList;
  S, ArqBol : String;
  B : TDadosBoleto;
  D : TDadosEmissaoBol;
  I : Integer;
begin
  tCli.Active := False;
  tCli.Active := True;
  Reg.Conta := Args[0];
  LI.liLoja := 0;
  LI.liOper := opAssinar;
  LI.liDetalhes.Add('Conta = ' + Reg.Conta);
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  if not tCli.Locate('EmailConta', Reg.Conta, []) then begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;
  LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  if not SameText(tCli.FieldByName('Senha').AsString, Args[1]) then begin
    Result := VarArrayOf(['Senha Incorreta']);
    Exit;
  end;
  if not tPrecos.Locate('Meses', Args[2], []) then begin
    Result := VarArrayOf(['Tipo de assinatura inválido']);
    Exit;
  end;
  
  SL := TStringList.Create;  SL2 := TStringList.Create;
  try
    InitTran(nxDB, [tCli, tRec], True);
    try
      SL.Text := Args[3];
      tCli.Edit;
      tCli.FieldByName('RazaoSocial').AsString := SL.Values['RazaoSocial'];
      tCli.FieldByName('CNPJ').AsString := SL.Values['CNPJ'];
      tCli.FieldByName('IE').AsString := SL.Values['IE'];
      tCli.FieldByName('Endereco').AsString := SL.Values['Endereco'];
      tCli.FieldByName('Cidade').AsString := SL.Values['Cidade'];
      tCli.FieldByName('UF').AsString := SL.Values['UF'];
      tCli.FieldByName('CEP').AsString := SL.Values['CEP'];
      tCli.FieldByName('Bairro').AsString := SL.Values['Bairro'];
      
      if Trim(SL.Values['Tel1'])>'' then
        sl2.Add(SL.Values['Tel1']);
      if Trim(SL.Values['Tel2'])>'' then
        sl2.Add(SL.Values['Tel2']);
      if Trim(SL.Values['Tel3'])>'' then
        sl2.Add(SL.Values['Tel3']);
      if Trim(SL.Values['Tel4'])>'' then
        sl2.Add(SL.Values['Tel4']);
      tCli.FieldByName('Telefones').AsString := sl2.Text;
      tCli.Post;

      tRec.Append;
      tRec.FieldByName('Premium').AsBoolean := True;
      tRec.FieldByName('Loja').AsInteger := LI.liLoja;
      tRec.FieldByName('Vencimento').AsDateTime := Date + 7;
      tRec.FieldByName('Lancamento').AsDateTime := Now;
      tRec.FieldByName('Valor').AsCurrency := tPrecos.FieldByName('Valor').AsCurrency;
      tRec.FieldByName('Premium').AsBoolean := True;
      tRec.FieldByName('ClienteLancou').AsBoolean := True;
      tRec.FieldByName('PremiumDias').AsInteger := tPrecos.FieldByName('Meses').AsInteger * 30;
      tRec.FieldByName('Descricao').AsString := tPrecos.FieldByName('Descr').AsString;
      tRec.Post;

      tRec.Edit;
      FB.Vencimento := tRec.FieldByName('Vencimento').AsDateTime;
      FB.DataDocumento := tRec.FieldByName('Lancamento').AsDateTime;
      FB.Valor := tRec.FieldByName('Valor').AsCurrency;
      FB.NossoNumero := tRec.FieldByName('ID').AsString;
      FB.Documento := tRec.FieldByName('ID').AsString;
      FB.Instrucoes.Text := tPrecos.FieldByName('Descr').AsString;

      FB.Sacado.Nome := SL.Values['RazaoSocial'];
      if Length(ApenasDig(SL.Values['CNPJ']))>11 then
        FB.Sacado.Pessoa := pJuridica else
        FB.Sacado.Pessoa := pFisica;
      FB.Sacado.CNPJ_CPF := ApenasDig(SL.Values['CNPJ']);  
      FB.Sacado.Endereco := SL.Values['Endereco'];
      FB.Sacado.Estado := SL.Values['UF'];
      FB.Sacado.Cidade := SL.Values['Cidade'];
      FB.Sacado.Cep  := SL.Values['CEP'];
      FB.Sacado.Bairro := SL.Values['Bairro'];
      FB.Preparar;

      ArqBol := 'Boleto'+tRec.FieldByName('ID').AsString+'.jpg';
      
      FBI.SaveBoletoImagem(ArqBol, 0);
      tRec.FieldByName('Doc').Value := FB.DadosGerados.LinhaDigitavel;
      tRec.Post;

      B.dbVenc := FB.Vencimento;
      B.dbLanc := FB.DataDocumento;
      B.dbNum := tRecID.AsInteger;
      B.dbValor := FB.Valor;
      B.dbDescr := FB.Instrucoes.Text;
      B.dbPagoEm := 0;
      B.dbCanceladoEm := 0;
      
      D.deNome := SL.Values['RazaoSocial'];
      D.deCNPJ  := SL.Values['CNPJ'];
      D.deEnd := SL.Values['Endereco'];
      D.deCidade := SL.Values['Cidade'];
      D.deUF := SL.Values['UF'];
      D.deCedente := FB.Cedente.Nome;

      nxDB.Commit;

      try
        tCorpo.Active := True;
        S := ExtractFilePath(ParamStr(0)) + 'email_assinatura.txt';
        if FileExists(S) then begin
          SL.LoadFromFile(S);
          S := SL.Text;
  
          repeat
            I := Pos('%NOMEASS', S);
            if I>0 then
              S := Copy(S, 1, I-1) + tPrecos.FieldByName('Descr').AsString + Copy(S, I+8, Length(S));
          until (I<1);
  
          repeat
            I := Pos('%VENCIMENTO', S);
            if I>0 then
              S := Copy(S, 1, I-1) + FormatDateTime('dd/mm/yyyy', B.dbVenc) + Copy(S, I+11, Length(S));
          until (I<1);
  
          repeat
            I := Pos('%ID', S);
            if I>0 then
              S := Copy(S, 1, I-1) + tRec.FieldByName('ID').AsString + Copy(S, I+3, Length(S));
          until (I<1);
          
          repeat
            I := Pos('%NUMBOLETO', S);
            if I>0 then
              S := Copy(S, 1, I-1) + tRec.FieldByName('Doc').AsString + Copy(S, I+10, Length(S));
          until (I<1);
  
          repeat
            I := Pos('%VALOR', S);
            if I>0 then
              S := Copy(S, 1, I-1) + FloatToStrF(B.dbValor, ffCurrency, 10, 2) + Copy(S, I+6, Length(S));
          until (I<1);
          
          tCorpo.Insert;
          tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
          tCorpoInclusao.Value := Now;
          tCorpoProcessou.Value := False;
          tCorpoDestino.Value := tCli.FieldByName('EmailConta').AsString;
          tCorpoAssunto.Value := 'NexCafé - Boleto de Assinatura';
          tCorpoCorpo.Value := S;
          tCorpoAnexos.Value := 'boleto.jpg='+ArqBol;
          tCorpo.Post;
  
        end;
        SL.Text := Args[3];
        
        SL.Insert(0, 'Conta = ' + Args[0]);
        SL.Insert(1, 'Num.Pedido = '  + tRec.FieldByName('ID').AsString);
        SL.Insert(2, 'Valor = ' + tPrecos.FieldByName('Valor').AsString);
        SL.Insert(3, tPrecos.FieldByName('Descr').AsString);
        SL.Insert(4, '');

        tCorpo.Insert;
        tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
        tCorpoInclusao.Value := Now;
        tCorpoProcessou.Value := False;
        tCorpoDestino.Value := TodosNextar;
        tCorpoAssunto.Value := 'NexCafé - ' + tPrecos.FieldByName('Descr').AsString;
        tCorpoCorpo.Value := SL.Text;
        tCorpoAnexos.Value := 'boleto.jpg='+ArqBol;
        tCorpo.Post;
      except
      end;
      
      Result := VarArrayOf(['OK', DadosEmissaoBolToVariant(D), BoletoToVariant(B)]);
    except
      nxDB.Rollback;
    end;
  finally
    SL.Free;
    SL2.Free;
  end;
  
end;

function TqsRegistro300.Ativar(const Args: array of Variant): Variant;
var 
  A, B : TCabAutorizacao;
  S: String;
begin
  tCli.Active := False;
  tCli.Active := True;
  Reg.Conta := Args[0];
  LI.liDetalhes.Add('Código de Ativaçăo = ' + Args[1]);
  LI.liLoja := 0;
  LI.liOper := opAtivarConta;
  if not tCli.Locate('EmailConta', Reg.Conta, []) then begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;
  LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  if tCli.FieldByName('Ativado').AsBoolean then
    Result := VarArrayOf(['Essa conta já está ativada']) 
  else
  if not SameText(tCli.FieldByName('CodAtivacao').AsString, Args[1]) then
    Result := VarArrayOf(['Código de Ativaçăo informado está incorreto'])
  else begin
    S := '';
    tCli.Edit;
    tCli.FieldByName('Ativado').AsBoolean := True;
    tCli.FieldByName('AtivadoEm').AsDateTime := Now;
    tCli.Post;
    tAut.IndexName := 'ILoja';
    tAut.SetRange([LI.liLoja, True], [LI.liLoja, True]);
    try
      while not tAut.Eof do begin
        if S>'' then S := S + ';';
        S := S + tAut.FieldByName('Autorizacao').AsString;
        if not tAut.FieldByName('EnviouCli').AsBoolean then begin
          tAut.Edit;
          tAut.FieldByName('EnviouCli').AsBoolean := True;
          tAut.Post;
        end;
        tAut.Next;
      end;
    finally
      tAut.CancelRange;
    end;
    Result := VarArrayOf(['OK', Reg.Conta, S, 0, False]);
  end;  
end;

function TqsRegistro300.AtualizaDadosConta(
  const Args: array of Variant): Variant;
var SL, sl2 : TStrings;  
begin
  tCli.Active := False;
  tCli.Active := True;
  Reg.Conta := Args[0];
  LI.liLoja := Reg.CodLoja;
  LI.liDetalhes.Add('Conta = ' + Args[0]);
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  LI.liDetalhes.Add('');
  LI.liDetalhes.Add(Args[2]);
  
  if (Reg.CodLoja=0) and not tCli.Locate('EmailConta', Reg.Conta, []) then
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  if (Reg.CodLoja>0) and not tCli.Locate('Codigo', Reg.CodLoja, []) then
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  
  if (not SameText(tCli.FieldByName('Senha').AsString, Args[1])) then
  begin
    Result := VarArrayOf(['Senha incorreta']);
    Exit;
  end;
  
  SL := TStringList.Create;
  sl2 := TStringList.Create;
  try
    SL.Text := Args[2];
    tCli.Edit;
    tCli.FieldByName('Loja').AsString := Sl.Values['Nome'];
    tCli.FieldByname('Proprietarios').AsString := Sl.Values['Prop'];
    tCli.FieldByName('Cidade').AsString := sl.Values['Cidade'];
    tCli.FieldByName('UF').AsString := sl.Values['UF'];
    tCli.FieldByName('AtualizadoEm').AsDateTime := Now;
    tCli.FieldByName('AtualizadoPor').AsString := 'Cliente';

    tCli.FieldByName('Endereco').AsString := SL.Values['Endereco'];
    tCli.FieldByName('Cidade').AsString := SL.Values['Cidade'];
    tCli.FieldByName('UF').AsString := SL.Values['UF'];
    tCli.FieldByName('CEP').AsString := SL.Values['CEP'];
    tCli.FieldByName('Bairro').AsString := SL.Values['Bairro'];
      
    if Trim(SL.Values['Tel1'])>'' then
      sl2.Add(SL.Values['Tel1']);
    if Trim(SL.Values['Tel2'])>'' then
      sl2.Add(SL.Values['Tel2']);
    if Trim(SL.Values['Tel3'])>'' then
      sl2.Add(SL.Values['Tel3']);
    if Trim(SL.Values['Tel4'])>'' then
      sl2.Add(SL.Values['Tel4']);
    tCli.FieldByName('Telefones').AsString := sl2.Text;
    
    tCli.Post;
  finally
    SL.Free;
    sl2.Free;
  end;

  Result := VarArrayOf(['OK']);
end;

function TqsRegistro300.ObtemBoletos(const Args: array of Variant): Variant;
var 
  I : Integer;
  aPend: Boolean;
  SIndex : String;
  A : TArrayBoleto;
  D : TDadosEmissaoBol;
begin  
  tCli.Active := False;
  tCli.Active := True;
  tRec.Active := False;
  tRec.Active := True;
  Reg.Conta := Args[0];
  aPend := Args[2];
  LI.liDetalhes.Add('Conta = ' + Args[0]);
  LI.liDetalhes.Add('Senha = '  +Args[1]);
  if aPend then
    LI.liDetalhes.Add('Boletos = Pendentes') else
    LI.liDetalhes.Add('Boletos = Todos');
    
  LI.liLoja := 0;
  if (Reg.CodLoja=0) and not tCli.Locate('EmailConta', Reg.Conta, []) then
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  if (Reg.CodLoja>0) and not tCli.Locate('Codigo', Reg.CodLoja, []) then
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  
  if (not SameText(tCli.FieldByName('Senha').AsString, Args[1])) then
  begin
    Result := VarArrayOf(['Senha incorreta']);
    Exit;
  end;

  SetLength(A, 0);   I := 0;

  tRec.IndexName := 'IPremiumLojaBaixou';
  if aPend then
    tRec.SetRange([True, LI.liLoja, False], [True, LI.liLoja, False]) else
    tRec.SetRange([True, LI.liLoja], [True, LI.liLoja]);
  try
    tRec.First;
    while not tRec.Eof do begin
      Inc(I);
      SetLength(A, I);
      A[I-1].dbVenc := tRecVencimento.Value;
      A[I-1].dbLanc := tRecLancamento.Value;
      A[I-1].dbNum := tRecID.Value;
      A[I-1].dbDescr := tRecDescricao.Value;
      A[I-1].dbValor := tRecValor.Value;
      A[I-1].dbPagoEm := tRecPagamento.Value;
      A[I-1].dbCanceladoEm := tRecCanceladoEm.Value;
      A[I-1].dbBaixou := tRecBaixou.Value;
      tRec.Next;
    end;
  finally
    tRec.CancelRange;
  end;

  if I>0 then begin
    D.deNome := tCliRazaoSocial.Value;
    D.deCNPJ := tCliCNPJ.Value;
    D.deEnd := tCliEndereco.Value;
    D.deCidade := tCliCidade.Value;
    D.deUF := tCliUF.Value;
    D.deCedente := FB.Cedente.Nome;
    Result := VarArrayOf(['OK', DadosEmissaoBolToVariant(D), ArrayBoletoToVariant(A)]);
  end else
  if aPend then
    Result := VarArrayOf(['Năo há boletos pendentes']) else
    Result := VarArrayOf(['Năo há boletos emitidos para sua conta']);
end;

