  object qCli: TffQuery
    DatabaseName = 'DB'
    SessionName = 'SesPad'
    SQL.Strings = (
      'Select Upper(Nome) as UNome,          '
      '       Codigo, Nome, Endereco, Bairro,'
      '       Cidade,UF,CEP,Nasc,Sexo,OBs    '
      ' From Contato                        '
      'Order by Nome')
