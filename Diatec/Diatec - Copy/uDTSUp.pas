function TkbmUp.ProcessRequest(const Func:string; const ClientIdent:TkbmMWClientIdentity; const Args:array of Variant):Variant;
var
   AFunc:string;
begin
  LI.Inicia(iolUpload);
  try
    FAlerta := '';
    dbDown.Active := False;
    dbDown.AliasPath := DownDir(dmbdServ.UltimoImp);
    dbDown.Active := True;
    tTec.Open;
    tOS.Open;
    tUOS.Open;
    tParametro.Open;
    tProj.Open;

     try
       AFunc:=UpperCase(Func);
       if AFunc='UPLOAD' then
          Result:=Upload(Args)
       else Result:=inherited ProcessRequest(Func,ClientIdent,Args);

       LI.liSucesso := True;
       dmBDServ.UltimoUp := LI.liLogID;
     except
       on E: Exception do begin
         LI.liSucesso := False;
         Result := 'Erro = '+E.Message;
         LI.liDetalhes.Add(Result);
       end;
     end;
  finally
    try
      if LI.liSucesso then begin
        mtLog.EmptyTable;
        mtLog.Active := True;
        LI.SalvaEsp(mtLog);
        Result := mtLog.AllData;
      end;
    except
    end;

    if FAlerta<>'' then begin
      LI.liDetalhes.Add('');
      LI.liDetalhes.Add(FAlerta);
    end;
    
    LI.Salva(nil, nil, nxSession);
  end;

  if (FAlerta>'') then
    Result := VarArrayOf([Result, FAlerta]);
end;


