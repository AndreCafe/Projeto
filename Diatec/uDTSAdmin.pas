// Master request processor.
//--------------------------

function TkbmDown.ProcessRequest(const Func:string; const ClientIdent:TkbmMWClientIdentity; const Args:array of Variant):Variant;
var
   AFunc:string;
begin
  LI.Inicia(iolDownload);
  LI.liDetalhes.Add('Etapa '+UpperCase(Func));
  try
    cpDown.Active := False;
    dbDown.Active := False;
    dbDown.AliasPath := DownDir(dmbdServ.UltimoImp);
    dbDown.Active := True;

     AFunc:=UpperCase(Func);
     if AFunc='DOWNLOAD1' then
        Result:=PerformDownload1(ClientIdent,Args)
     else 
     if AFunc='DOWNLOAD2' then
        Result:=PerformDownload2(ClientIdent,Args)
     else
       Result:=inherited ProcessRequest(Func,ClientIdent,Args);
  finally
    try
      LI.liSucesso := (VarType(Result) <> varString) and (VarType(Result)<>varOleStr);
      if not LI.liSucesso then begin
        LI.liDetalhes.Add('');
        LI.liDetalhes.Add('Erro = '+Result);
      end;  
    except
    end;  
    LI.Salva(nil, nil, nxSession);
  end;  
end;


