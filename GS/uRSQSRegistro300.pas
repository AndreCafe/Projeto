function TqsRegistro300.ObtemParamAss(const Args: array of Variant): Variant;
var 
  A: TArrayAssinatura;
  I: Integer;
  S, sOqueE : String;
  sTermos : String;
  SL : TStringList;
begin
  tPrecos.Active := True;
  SetLength(A, tPrecos.RecordCount);
  I := 0;
  tPrecos.IndexName := 'IMeses';

  if Length(Args)>0 then begin
    tCli.Active := False;
    tCli.Active := True;
    Reg.Conta := Trim(Args[0]);
    LI.liDetalhes.Add('Conta = ' + Args[0]);
    LI.liDetalhes.Add('Senha = '  +Args[1]);
    LI.liLoja := 0;
    LI.liOper := opObtemParamAss;
    tCli.IndexName := 'IEmailConta';
    if not tCli.FindKey([Reg.Conta]) then begin
      Result := VarArrayOf(['Conta inexistente']);
      Exit;
    end;
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
    tPrecos.SetRange([tCliCodDesc.Value], [tCliCodDesc.Value]);
  end else
    tPrecos.SetRange([''], ['']);

  try
    tPrecos.First;
    while not tPrecos.Eof do begin
      if tPrecos.FieldByName('DispCli').AsBoolean then begin
        A[I].prDescr := tPrecos.FieldByName('Descr').AsString;
        A[I].prValor := tPrecos.FieldByName('Valor').AsCurrency;
        A[I].prMeses := tprecos.FieldByName('Meses').AsInteger;
      end;
      tPrecos.Next;
      Inc(I);
    end;
  finally
    tPrecos.CancelRange;
  end;

  sTermos := '';
  sOqueE := '';

  SL := TStringList.Create;
  try
    S := ExtractFilePath(ParamStr(0))+'oqueepremium.txt';
    if FileExists(S) then begin
      SL.LoadFromFile(S);
      sOqueE := SL.Text;
    end;

    S := ExtractFilePath(ParamStr(0))+'termos.txt';
    if FileExists(S) then begin
      SL.LoadFromFile(S);
      sTermos := SL.Text;
    end;
  finally
    SL.Free;
  end;

  Result := VarArrayOf([sOqueE, sTermos, ArrayAssinaturaToVariant(A)]);
end;

function TqsRegistro300.ObtemContaPorEmail(
  const Args: array of Variant): Variant;
begin
  Result := VarArrayOf(['']);
  if (Args[0]=null) or (Trim(Args[0])='') then Exit;

  qCli.Active := False;
  qCli.SQL.Text := 'select * from cliente where emailreg like ' + QuotedStr('%'+Args[0]+'%');
  qCli.Open;
  try
    if qCli.IsEmpty then
      Result := '' else
      Result := EnviaEmailRegistros(qCli, Args[0]);
    if Result='' then
      Result := VarArrayOf(['']) else
      Result := VarArrayOf(['OK', Result]); 
  finally
    qCli.Active := False;
  end;
end;

