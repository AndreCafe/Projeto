procedure TkbmUp.TransfTable(F: TDataSet; D: TnxTable; idTab: Integer);
var 
  I, Cnt : Integer;
  C : TField;
  Oper: Byte;
begin
  F.First;
  Cnt := 0;
  while not F.Eof do begin
    Inc(FImportou);

    Oper := opupImportar;
    
    case idTab of
      idtbOS : begin
        ValidaOS(F);
        ProcessaFlagApagarOS(F);
      end;

      idtbOSFase : ProcessaFlagApagarOSFase(F);
      idtbOSFaseDesc : ProcessaFlagApagarOSFaseDesc(F);
      
      
      idtbRA : ValidaRA(F.FieldByName('DataF').AsDateTime);
      idtbRAItem : ValidDespesa(D, Oper, F);
      idtbRAOS : ChecaOSRA(F.FieldByName('Cliente').AsString,
                           F.FieldByName('Tecnico').AsString, 
                           F.FieldByName('DataOS').AsDateTime,
                           F.FieldByName('IDOS').AsInteger);
    end;  

    if Oper in [opupImportar, opupEditar] then begin
      if Oper=opupImportar then
        D.Insert
      else
        D.Edit;  
  
      for I := 0 to D.FieldCount-1 do with D.Fields[I] do
      if (UpperCase(FieldName)<>'IDDIATEC') then begin
        C := F.FindField(FieldName);
        if C <> nil then
          Value := C.Value;
      end;
      D.FieldByName('Sync').AsBoolean := True;
      C := D.FindField('DownOK');
      if C<>nil then C.AsBoolean := False;

      C := D.FindField('OnServ');
      if C<>nil then C.AsBoolean := True;
      
      D.FieldByName('LogID').AsInteger := LI.liLogID;
      D.Post;
    end;
      
    Sleep(0);
    Inc(Cnt);
    if Cnt>1000 then begin
      Debug('Loop infinito KbmUp.TransfTable');
      Break;
    end;
    F.Next;
  end;
  if idTab=idtbOS then LI.liDetalhes.Add('');
end;

function TkbmUp.Upload(const Args: Array of Variant): Variant;
var 
  Tentar, I, N : Integer;
  Usuario, Senha, VersaoCli: String; 


procedure Transf(V : Variant; idTab: Integer);
begin
  if V=null then Exit;
  MT.Active := False;
  Tab.Active := False;
  MT.AllData := V;
  MT.Active := True;
  if idTab in [idtbRA..idtbRAFTec] then
    Tab.TableName := NomeTab[idTab]
  else  
    Tab.TableName := 'U'+NomeTab[idTab];
    
  Tab.IndexName := '';
  Tab.Open;
  LI.liDetalhes.Add('Tabela '+NomeTab[idTab]+' - '+IntToStr(MT.RecordCount)+' registro(s)');
  TransfTable(MT, Tab, idTab);
end;

begin
  Usuario := Args[0];
  Senha := Args[1];
  VersaoCli := Args[2];
  if VersaoCli <> cfgVersao then
    Raise Exception.Create(
      'Vers„o do seu Diatec Cliente ('+VersaoCli+
      ') ť diferente da vers„o do servidor Diatec ('+cfgVersao+'). ' +
      '… necessŠrio atualizar seu Diatec Cliente.');

  Result := '';
  FUsuario := Usuario;
  FSenha := Senha;
  ChecaLogin;
  Tentar := 20;
  tRAF.Active := True;
  tRAF.IndexName := 'IDataF';
  tParametro.Active := True;
  tParametro.Refresh;
  while Tentar>0 do begin
    InitTran(dbUpload, [], False);
    try
      FImportou := 0;
      N := 2;
      for I := 1 to NumTabs do
      if UploadTab[I] then begin
        Inc(N);
        Transf(Args[N], I);
      end;  
      if FImportou=0 then
        Raise Exception.Create('N„o hŠ registros a serem importados!');
      dbUpload.Commit;
      Tentar := 0;
    except
      dbUpload.Rollback;
      if Tab.State in [dsEdit, dsInsert] then Tab.Cancel;
      Dec(Tentar);
      if Tentar=0 then Raise;
      Sleep(Random(500));
    end;
  end;
end;

procedure TkbmUp.ChecaLogin;
begin
  LI.liTecnico := FUsuario;
  if not LicencaGlobal.SenhaOk then
    Raise Exception.Create('Diatec n„o licenciado');

  if (not tTec.FindKey([FUsuario])) or (UpperCase(tTecSenha.Value) <> UpperCase(FSenha)) then
  begin
    LI.liDetalhes.Add('Tťcnico = '+FUsuario);
    LI.liDetalhes.Add('Senha   = '+FSenha);
    Raise
      Exception.Create('UsuŠrio ou Senha invŠlida');
  end;
end;


procedure TkbmUp.kbmMWCustomServiceCreate(Sender: TObject);
begin
  dbPar.AliasName := NomeAlias(cDiatecPar);
  dbPar.Active := True;

  dbUpload.Enabled := False;
  dbUpload.AliasName := NomeAlias(cDiatecUp);
  dbUpload.Enabled := True;
  dbUpload.Active := True;

  dbDown.Enabled := False;
  dbDown.AliasPath := DownDir(dmBDServ.UltimoImp);
  dbDown.Enabled := True;
  dbDown.Active := True;
  tTec.Open;

  LI := TLogInfo.Create;
end;

procedure TkbmUp.kbmMWCustomServiceDestroy(Sender: TObject);
begin
  LI.Free;
end;

function ConflitoHorario(I1, T1, I2, T2: TDateTime): Boolean;
begin
  Result := (I1 < T2) and (I2 < T1);
end;

function TkbmUp.ConflitoOSID(Cliente, IDTecnico: String;
                             Dia, Inicio, Termino: TDateTime;
                             ID: Word): Boolean;
begin
  Result := ConflitoOSIDEx(tOS, Cliente, IDTecnico, Dia, Inicio, Termino, ID) or
            ConflitoOSIDEx(tUOS, Cliente, IDTecnico, Dia, Inicio, Termino, ID);
end;

function TkbmUp.ConflitoOSIDEx(T: TnxTable; Cliente, IDTecnico: String;
                              Dia, Inicio, Termino: TDateTime;
                              ID: Word): Boolean;
var DownOk: Boolean;                              
begin
  T.Active := True;
  T.CancelRange;
  if tParametroConflitoHoraTodosCli.Value then begin
    T.IndexName := 'ITecnico';
    T.SetRange([IDTecnico, Dia], [IDTecnico, Dia]);
  end else begin
    T.IndexName := 'IID';
    T.SetRange([Cliente, IDTecnico, Dia], [Cliente, IDTecnico, Dia]);
  end;

  T.Refresh;
  T.First;
  Result := True;
  while not T.Eof do begin
    DownOk := SameText('U', Copy(T.TableName, 1, 1)) and
              T.FieldByName('DownOk').AsBoolean;
              
    if not DownOk then
    if (not SameText('S', T.FieldByName('Apagar').AsString)) and 
       ConflitoHorario(T.FieldByName('Inicio').AsDateTime,
                       T.FieldByName('Termino').AsDateTime,
                       Inicio, Termino) then Exit;
    T.Next;
  end;

  Result := False;
end;


function TkbmUp.TemTranslado(Cliente, IDTecnico: String; Dia: TDateTime; ID: Word): Boolean;
begin
  Result := TemTransladoEx(tOS, Cliente, IDTecnico, Dia, ID) or
            TemTransladoEx(tUOS, Cliente, IDTecnico, Dia, ID);
end;

function TkbmUp.TemTransladoEx(T: TnxTable; Cliente, IDTecnico: String; Dia: TDateTime; ID: Word): Boolean;
var DownOk : Boolean;
begin
  T.Active := True;
  T.CancelRange;
  T.IndexName := 'IID';
  T.SetRange([Cliente, IDTecnico, Dia], [Cliente, IDTecnico, Dia]);
  T.Refresh;
  T.First;
  Result := True;
  while not T.Eof do begin
    DownOk := SameText('U', Copy(T.TableName, 1, 1)) and
              T.FieldByName('DownOk').AsBoolean;
              
    if not DownOk then
    if {(T.FieldByName('ID').AsInteger<>ID) and} (not SameText(T.FieldByName('Apagar').AsString, 'S')) and 
       (FormatDateTime('hh:mm', T.FieldByName('Translado').AsDateTime) > '00:00')
    then
      Exit;
    T.Next;
  end;  
  Result := False;  
end;

procedure TkbmUp.Debug(S: String);
begin
  TLogInfo.Debug(S, nil, nil, nxSession);
end;


procedure TkbmUp.ChecaOSRA(Cliente, IDTec: String; DataOS: TDateTime;
  IDOS: Word);
begin
{  tRAOS.Active := True;
  tRAOS.IndexName := 'IOS';
  if tRAOS.FindKey([IDTec, Cliente, DataOS, IDOS]) then 
    Raise Exception.Create('JŠ foi gerado um relatůrio de atendimento para a OS do Cliente ' +
                           Cliente + ' / Tťcnico ' + IDTec + ' Data ' + FormatDateTime('dd/mm/yyyy', DataOS) + 
                           ' ID-OS ' + IntToStr(IDOS));}
end;

