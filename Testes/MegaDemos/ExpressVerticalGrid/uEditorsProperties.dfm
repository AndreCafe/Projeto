              Left = 19
              Top = 25
              Hint = 
                'Use the ShowColumnLines property to specify the visibility of co' +
                'lumn lines.  If set to True, column lines are displayed.  Otherw' +
                'ise, they are hidden. '
              Caption = 'ShowColumnLines'
              Properties.OnChange = cbMCListBoxShowColumnLinesPropertiesChange
              TabOrder = 0
              Width = 139
            end
            object cbCMListBoxShowEndEllipsis: TcxCheckBox
              Left = 158
              Top = 25
              Hint = 
                'If values don'#8217't fit into columns you can force them to be word w' +
                'rapped by setting the MultiLines property to True.  Otherwise, s' +
                'uch values are displayed in a single line.  In this case, you ca' +
                'n specify whether ellipses must be displayed at the end of value' +
                's that don'#8217't fit into columns.  To display them set the ShowEndE' +
                'llipsis property to True.  Otherwise, values are simply truncate' +
                'd by the column border.'
              Caption = 'ShowEndEllipsis'
              Properties.OnChange = cbCMListBoxShowEndEllipsisPropertiesChange
              TabOrder = 1
              Width = 148
            end
