function Pad(S: String; Len: Integer): String;
begin
  Result := S;
  while Length(Result)<Len do Result := Result +  ' ';
end;

procedure TkbmUp.ValidaOS(F: TDataSet);
begin
  if not SameText(F.FieldByName('Apagar').AsString, 'S') then begin
    if tParametroChecarVersaoProj.Value then begin
      if not tProj.FindKey([F.FieldByName('Cliente').AsString, F.FieldByName('Projeto').AsString]) then
        Raise Exception.Create('Projeto do Cliente ' + F.FieldByName('Cliente').AsString + ' com ID ' +
                               F.FieldByName('Projeto').AsString + ' n„o existe na base de download mais recente.');
      if not SameText(tProj.FieldByName('VersaoProj').AsString, F.FieldByName('VersaoProj').AsString) then
        Raise Exception.Create('JŠ existe uma nova vers„o de projeto. SerŠ necessŠrio fazer novo download');
    end;
    
    if ConflitoOSID(F.FieldByName('Cliente').AsString, F.FieldByName('Tecnico').AsString, F.FieldByName('Data').AsDateTime, F.FieldByName('Inicio').AsDateTime, F.FieldByName('Termino').AsDateTime, F.FieldByName('ID').AsInteger) then
      raise Exception.Create('JŠ existe OS na mesma faixa de horŠrio da OS ' + F.FieldByName('ID').AsString + '. … necessŠrio fazer um novo download e refazer a(s) OS(s)');
    if FormatDateTime('hhmm', F.FieldByName('Translado').AsDateTime) > '0000' then
      if TemTranslado(F.FieldByName('Cliente').AsString, F.FieldByName('Tecnico').AsString, F.FieldByName('Data').AsDateTime, F.FieldByName('ID').AsInteger) then
        raise Exception.Create('JŠ existe translado para esse cliente/dia. ' + '… necessŠrio fazer um novo download e refazer a(s) OS(s)');
  end;
  
  if F.Bof then
  begin
    LI.liDetalhes.Add('========================================================================');
    LI.liDetalhes.Add(' Cliente Data       ID-OS Inicio Termino Transl Abono Num.Atend Apagar');
    LI.liDetalhes.Add('========================================================================');
  end;
  LI.liDetalhes.Add(' ' + 
                    Pad(F.FieldByName('Cliente').AsString, 8) + 
                    FormatDateTime('dd/mm/yyyy', F.FieldByName('Data').AsDateTime) + ' ' + 
                    Pad(F.FieldByName('ID').AsString, 6) + 
                    FormatDateTime('hh:mm', F.FieldByName('Inicio').AsDateTime) + '  ' + 
                    FormatDateTime('hh:mm', F.FieldByName('Termino').AsDateTime) + '   ' + 
                    FormatDateTime('hh:mm', F.FieldByName('Translado').AsDateTime) + '  ' + 
                    FormatDateTime('hh:mm', F.FieldByName('Abono').AsDateTime) + ' ' + 
                    Pad(F.FieldByName('NumAtend').AsString, 10) +
                    VariantToSN(F.FieldByName('Apagar').Value));
end;

procedure TkbmUp.ValidaRA(D: TDateTime);
begin
  if FAlerta<>'' then Exit;
  tRAF.Refresh;
  if tRAF.IsEmpty then Exit; 
  tRAF.FindNearest([D]);
  if (tRAF.FieldByName('DataF').AsDateTime >= D) then
    FAlerta := 'ATEN«√O: JŠ existe uma consolidaÁ„o em andamento. … provavel que as despesas apontadas sejam consolidadas somente no průximo mÍs';
end;

procedure TkbmUp.ValidDespesa(var D: TnxTable; var Oper: Byte; F: TDataSet);
var
  Achou: Boolean;
begin
  D.IndexName := 'IID';
  Achou := D.FindKey([F.FieldByName('Tecnico').AsString, F.FieldByName('Cliente').AsString, F.FieldByName('ID').AsInteger]);
  if F.FieldByName('ExcluirServ').AsBoolean then
  begin
    Oper := 0;
    if Achou then
      D.Delete;
  end else
  begin
    if Achou then begin
      if F.FieldByName('OnServ').AsBoolean then
        Oper := opupEditar
      else
        raise Exception.Create('JŠ existe uma despesa com nķmero ' + F.FieldByName('ID').AsString + ' do tťcnico ' + F.FieldByName('Tecnico').AsString + ' e cliente ' + F.FieldByName('Cliente').AsString + '. SerŠ necessŠrio fazer novo download');
    end else begin
      if F.FieldByName('OnServ').AsBoolean then
        raise Exception.Create('Despesa n„o encontrada para atualizaÁ„o. Nķmero ' + F.FieldByName('ID').AsString + ' do tťcnico ' + F.FieldByName('Tecnico').AsString + ' e cliente ' + F.FieldByName('Cliente').AsString + '. SerŠ necessŠrio fazer novo download')
      else
        Oper := opupImportar;        
    end;
  end;
end;


// Master request processor.
//--------------------------

procedure TkbmUp.ProcessaFlagApagarOS(F: TDataset);
begin
  if not SameText(F.FieldByName('Apagar').AsString, 'S') then Exit;
  if not tParametroPermiteApagarOSSincronizada.Value then
    Raise Exception.Create('N„o ť permitido apagar OS que jŠ foi sincronizada');

  Q.SQL.Text := 'update UOS set Apagar = ' + QuotedStr('S');
  Q.SQL.Add(
    Format(' where (cliente = %s) and (tecnico = %s) and (data = :Data) and (ID = %d)',
    [QuotedStr(F.FieldByName('Cliente').AsString), 
     QuotedStr(F.FieldByName('Tecnico').AsString),
     F.FieldByName('ID').AsInteger]));
  Q.ParamByName('Data').AsDateTime := F.FieldByName('Data').AsDateTime;   
  Q.ExecSQL;    
end;

procedure TkbmUp.ProcessaFlagApagarOSFase(F: TDataset);
begin
  if not SameText(F.FieldByName('Apagar').AsString, 'S') then Exit;
  Q.SQL.Text := 'update UOSFase set Apagar = ' + QuotedStr('S');
  Q.SQL.Add(
    Format(' where (cliente = %s) and (projeto = %s) and (fase = %s) and (tecnico = %s) and (item = %d)',
    [QuotedStr(F.FieldByName('Cliente').AsString), 
     QuotedStr(F.FieldByName('Projeto').AsString),
     QuotedStr(F.FieldByName('Fase').AsString),
     QuotedStr(F.FieldByName('Tecnico').AsString),
     F.FieldByName('Item').AsInteger]));
  Q.ExecSQL;   
end;

procedure TkbmUp.ProcessaFlagApagarOSFaseDesc(F: TDataset);
begin
  if not SameText(F.FieldByName('Apagar').AsString, 'S') then Exit;
  Q.SQL.Text := 'update UOSFaseDesc set Apagar = ' + QuotedStr('S');
  Q.SQL.Add(
    Format(' where (cliente = %s) and (projeto = %s) and (fase = %s) and (tecnico = %s) and (item = %d)',
    [QuotedStr(F.FieldByName('Cliente').AsString), 
     QuotedStr(F.FieldByName('Projeto').AsString),
     QuotedStr(F.FieldByName('Fase').AsString),
     QuotedStr(F.FieldByName('Tecnico').AsString),
