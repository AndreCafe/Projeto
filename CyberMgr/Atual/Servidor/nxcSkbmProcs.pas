     Result:='procsbase';
end;

procedure TkbmProcs.kbmMWCustomServiceCreate(Sender: TObject);
begin
  nxSession.ServerEngine := dmServidorBD.ServerEngine;
end;

procedure TkbmProcs.LimpaFundo(aDesktop: Boolean);
var S: String;
begin
  if aDesktop then 
    S := NomeArqDesktop(False) else
    S := NomeArqLogin(False);

  if S='' then Exit;
   
  InitTran(nxDB, [tConfig], True);
  try  
    tConfig.Edit;
    if aDesktop then
      tConfigTipoFDesktop.Value := '' else
      tConfigTipoFLogin.Value := '';
    tConfig.Post;
    if FileExists(S) then 
      TThreadRename.Create(S, '');
    nxDB.Commit;  
    MudouFundo;
  except
    nxDB.Rollback;
    Raise;
  end;
end;

procedure TkbmProcs.MudouFundo;
begin
  dmKbmServ.mwTCPIP.SendMessage('MSG.TODOS.MUDOUFUNDO', '', dmKbmServ.FCI, nil,
                                [ExtractFileName(NomeArqDesktop(True)),
                                 ExtractFileName(NomeArqLogin(True))]);
end;

function TkbmProcs.NomeArqDesktop(aChecarExist: Boolean): String;
var NewTran: Boolean;
begin
  if SameText(tConfigTipoFDesktop.Value, 'JPG') then begin
    Result := ExtractFilePath(ParamStr(0)) + 'DADOS\DESKTOP' + tConfigNumFDesktop.AsString + '.JPG';
{    if aChecarExist and (not FileExists(Result)) then begin
      Result := '';
      NewTran := not nxDB.InTransaction;
      if NewTran then
        InitTran(nxDB, [tConfig], True);
      try
        tConfig.Edit;
        tConfigTipoFDesktop.Value := '';
        tConfig.Post;
        if NewTran then
          nxDB.Commit;
      except
        if NewTran then
          nxDB.Rollback;
        Raise;  
      end;  
    end; }
  end else
    Result := '';
end;

function TkbmProcs.NomeArqFundo: Variant;
begin
  Result := VarArrayOf([ExtractFileName(NomeArqDesktop(True)), ExtractFileName(NomeArqLogin(True))]);
end;

function TkbmProcs.NomeArqLogin(aChecarExist: Boolean): String;
var NewTran : Boolean;
begin
  if tConfigTipoFLogin.Value>'' then begin
    Result := ExtractFilePath(ParamStr(0)) + 'DADOS\LOGIN'+tConfigNumFLogin.AsString+'.'+tConfigTipoFLogin.Value;
{    if aChecarExist and (not FileExists(Result)) then begin
      Result := '';
      NewTran := not nxDB.InTransaction;
      if NewTran then
        InitTran(nxDB, [tConfig], True);
      try
        tConfig.Edit;
        tConfigTipoFLogin.Value := '';
        tConfig.Post;
        if NewTran then
          nxDB.Commit;
      except
        if NewTran then
          nxDB.Rollback;
        Raise;  
      end;  
    end;   }
  end else
    Result := '';
end;

procedure TkbmProcs.NovoFundo(aDesktop: Boolean; aNomeArq: String);
var S, SAnt: String;
begin
  aNomeArq := UpperCase(ExtractFilePath(ParamStr(0))+'DADOS\'+aNomeArq);
  if not FileExists(aNomeArq) then
    Raise Exception.Create('Arquivo ' + aNomeArq + ' n緌 encontrado');
  if aDesktop then begin
    S := ExtractFileExt(aNomeArq);
    if not SameText(S, '.JPG') then
      Raise Exception.Create('O arquivo de fundo para 嫫ea de trabalho tem que ser do tipo JPG');
    InitTran(nxDB, [tConfig], True);
    try  
      tConfig.Refresh;
      SAnt := NomeArqDesktop(False);
      tConfig.Edit;
      tConfigNumFDesktop.Value := tConfigNumFDesktop.Value + 1;
      tConfigTipoFDesktop.Value := 'JPG';
      tConfig.Post;
      S := NomeArqDesktop(False);
      TThreadRename.Create(S, aNomeArq);
      if SAnt<>'' then
        TThreadRename.Create(SAnt, '');
      nxDB.Commit;
      MudouFundo;
    except
      nxDB.Rollback;
      Raise;
    end;
  end else begin
    S := ExtractFileExt(aNomeArq);
    if (not SameText(S, '.JPG')) and (not SameText(S, '.GIF')) then
      Raise Exception.Create('O arquivo de fundo para a tela de login tem que ser do tipo JPG ou GIF');
    InitTran(nxDB, [tConfig], True);
    try  
      tConfig.Refresh;
      SAnt := NomeArqLogin(False);
      tConfig.Edit;
      tConfigNumFLogin.Value := tConfigNumFLogin.Value + 1;
      tConfigTipoFLogin.Value := Copy(S, 2, 3);
      tConfig.Post;
      S := NomeArqLogin(False);  
      TThreadRename.Create(S, aNomeArq);
      if SAnt<>'' then
        TThreadRename.Create(SAnt, '');
      nxDB.Commit;
      MudouFundo;
    except
      nxDB.Rollback;
      Raise;
    end;
  end;
end;

function TkbmProcs.ObtemSenha(aContato: Integer): String;
begin
  tCli.Refresh;
  if tCli.FindKey([aContato]) then
    Result := tCliSenha.Value
  else
    Raise Exception.Create('Cliente com c鏚igo '+IntToStr(aContato)+' n緌  foi encontrado no banco de dados!');
end;

function TkbmProcs.ProcessRequest(const Func: string;
  const ClientIdent: TkbmMWClientIdentity;
  const Args: array of Variant): Variant;
var S: String;  
begin
  nxSession.Active := True;
  nxDB.Active := True;
  tConfig.Active := True;
  tCli.Active := True;
  
  S := UpperCase(Func);
  try
    if S='TROCASENHA' then
      TrocaSenha(Args[0], Args[1])
    else
    if S='NOVOFUNDO' then
      NovoFundo(Args[0], Args[1])
    else  
    if S='LIMPAFUNDO' then
      LimpaFundo(Args[0])
    else  
    if S='NOMEARQFUNDO' then
      Result := NomeArqFundo
    else  
    if S='OBTEMSENHA' then
      Result := ObtemSenha(Args[0])
    else  
      raise Exception.Create('Fun誽o ' + Func + ' inexistente no servidor'); 
  except
    On E: Exception do
      kbmMWRaiseException(E.Message);
  end;
end;

procedure TkbmProcs.TrocaSenha(aContato: Integer; aNovaSenha: String);
begin
  nxSession.Active := True;
  nxDB.Active := True;
  tCli.Active := True;
  if not tCli.FindKey([aContato]) then
    kbmmwRaiseException('Erro ao trocar senha. O cliente c鏚igo ' + IntToStr(aContato) + ' n緌 foi encontrado no banco de dados!');
  InitTran(nxDB, [tCli], True);
  try    
    tCli.Edit;
    tCliSenha.Value := aNovaSenha;
    tCli.Post;
    nxDB.Commit;
  except
    nxDB.Rollback;
    Raise;
  end;
end;

{$IFNDEF CPP}class{$ENDIF} function TkbmProcs.GetFlags:TkbmMWServiceFlags;
begin
     Result:=[mwsfListed];
end;


end.