procedure TqsRegistro100.LeLicencaTab(var Lic: TLicenca);
begin
  Lic.liCodLoja := tAut.FieldByName('Loja').AsInteger;
  Lic.liSerialHD := tAut.FieldByName('CodigoEquip').AsString;
  Lic.liMaquinas := tAut.FieldByName('Maquinas').AsInteger;
  Lic.liVencimento := tAut.FieldByName('Vencimento').AsDateTime;
  Lic.liTipo  := AutorizacaoParaLicenca(tAut.FieldByname('Tipo').AsInteger);
  Lic.liSenha := LimpaTraco(Lic.SenhaCorreta);
end;

function TqsRegistro100.ProcessRequest(const Func: string;
  const ClientIdent: TkbmMWClientIdentity;
  const Args: array of Variant): Variant;
var 
  uFunc : String;  
begin
  CheckDB;
  
  Inc(nRequests[0]);


  uFunc := UpperCase(Func);
  try
    if uFunc='OBTEMLICENCATESTE' then begin
      LI.Inicia(opCriarConta, ClientIdent.RemoteLocation);
      Result := ObtemLicencaTeste(Args);
    end else
    if uFunc='MODODEMO' then begin
      LI.Inicia(opModoDemo, ClientIdent.RemoteLocation);
      Result := LogModoDemo(Args);
    end else
    if uFunc='OBTEMLICENCA' then begin
      LI.Inicia(opChecaConta, ClientIdent.RemoteLocation);
      Result := self.ObtemLicenca(Args);
    end else  
    if uFunc='TROCAHD' then begin
      LI.Inicia(opTrocaHD, ClientIdent.RemoteLocation);
      Result := TrocaHD(Args)
    end else  
    if uFunc='ATUALIZACADASTRO' then begin
      LI.Inicia(opAtualizaDadosConta, ClientIdent.RemoteLocation);
      Result := AtualizaCadastro(Args);
    end else  
    if uFunc='OBTEMCADASTRO' then begin
      LI.Inicia(opObtemDadosConta, ClientIdent.RemoteLocation);
      Result := ObtemCadastro(Args);
    end else begin
      DebugMsg('TqsRegistro100.NAO_ACHOU_FUNC');
      Result := inherited ProcessRequest(Func, ClientIdent, Args)
    end;
  except
    On E: Exception do begin
      DebugMsg('TqsRegistro100.ProcessRequest - uFunc: ' + uFunc + ' - E: ' + E.Message);
    
      Result := VarArrayOf(['Erro năo esperado no servidor de registro: ' + E.Message]);
    end;
  end;  
  try 
    if Result[0] = 'OK' then
      LI.liOK := True
    else begin 
      LI.liOK := False;
      LI.liDetalhes.Add('RESULTADO = ' + Result[0]);
    end;  
  except
  end;
  
  if not (LI.liOper in [opModoDemo, opObtemDadosConta]) then
    LI.SaveToDataset(tLog);  
end;

procedure TransfDados(O, D: TDataset; Tudo: Boolean);
var 
  I : Integer;
  F : TField;
begin
  for I := 0 to D.FieldCount-1 do with D.Fields[I] do 
  if Tudo or ((DataType<>ftAutoInc) and (Pos('|'+UpperCase(FieldName)+'|', CamposReadOnly)=0)) then 
  begin
    F := O.FindField(FieldName);
    if F<>nil then
      Value := F.Value;
  end;  
end;
    
function TqsRegistro100.ObtemLicencaTeste(
  const Args: array of Variant): Variant;
var 
  FLic : TLicenca;
  SIndex : String;
  SLE : TStrings;
  S : String;
  Dia : TDateTime;
begin
  Result := VarArrayOf([
    'Atençăo: O Cyber Manager foi substituído pelo NexCafé. '+
    'Favor fazer download do NexCafé em www.nexcafe.com.br e realizar seu registro']);
  Exit;  
    
  MT.Active := False;
  MT.Active := True;
  MT.AllData := Args[0];
  LI.liHD := MT.FieldByName('SerieHD').AsString;
  SIndex := tLog.IndexName;
  tLog.IndexName := 'IHDOperOk';
  try
    if tLog.FindKey([LI.liHD, opCriarConta, True]) then begin
      Result := VarArrayOf(['Já foi concedido anteriormente uma licença para teste para esse mesmo disco rígido. '+
                'Envie E-mail para vendas@nextar.com.br solicitando uma prorrogaçăo do seu período de teste gratuito.']);
      Exit;
    end;                
      
    tCli.Active := False;
    tCli.Active := True;
    tCli.Insert;
    TransfDados(MT, tCli, False);
    tCli.FieldByName('Codigo').Clear;
    tCli.FieldByName('LicMaq').AsInteger := tCli.FieldByName('NumMaq').AsInteger;
    tCli.FieldByName('LicTipo').AsInteger := tlTeste;
    Dia := Date + 7;
    while DayOfWeek(Dia) in [1, 7] do Dia := Dia + 1;
    tCli.FieldByName('LicVenc').AsDateTime := Dia;
    tCli.FieldByName('CadastroEm').AsDateTime := Now;
    tCli.FieldByName('CadastroPor').AsString := 'Cliente';
    tCli.FieldByName('Programa').AsInteger := 0;
    tCli.FieldByName('AtualizadoEm').AsDateTime := Now;
    tCli.FieldByName('AtualizadoPor').AsString := 'Cliente';
    if DayOfWeek(tCli.FieldByName('LicVenc').AsDateTime) = 1 then
      tCli.FieldByName('LicVenc').AsDateTime := tCli.FieldByName('LicVenc').Value + 1;
      
    if DayOfWeek(tCli.FieldByName('LicVenc').AsDateTime) = 7 then
      tCli.FieldByName('LicVenc').AsDateTime := tCli.FieldByName('LicVenc').AsDateTime + 2;
  
    tCli.Post;

    tAut.Insert;
    tAut.FieldByName('Loja').AsInteger := tCli.FieldByName('Codigo').AsInteger;
    tAut.FieldByName('Programa').AsInteger := 0;
    tAut.FieldByName('Vencimento').AsDateTime := tCli.FieldByName('LicVenc').AsDateTime;
    tAut.FieldByName('Maquinas').AsInteger := tCli.FieldByName('LicMaq').AsInteger;
    tAut.FieldByName('Tipo').AsInteger := taTesteGratuito;
    tAut.FieldByName('CodigoEquip').AsString := tCli.FieldByName('SerieHD').AsString;
    tAut.FieldByName('CriadaEm').AsDateTime := Now;
    tAut.FieldByName('CriadaPor').AsString := 'cliente';
    tAut.FieldByName('Ativa').AsBoolean := True;
    tAut.FieldByName('Gerar').AsBoolean := False;
    tAut.FieldByName('EnviouCli').AsBoolean := True;
    LeLicencaTab(FLic);
    FLic.liSenha := FLic.SenhaCorreta;
    tAut.FieldByName('Autorizacao').AsString := FLic.AsStringSemHD;
    tAut.Post;
    
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
    LI.liHD := FLic.liSerialHD;
    Result := VarArrayOf(['OK', FLic.AsString]);
    SLE := TStringList.Create;
    try
      tCorpo.Active := True;
      tCorpo.Insert;
      tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
      tCorpoInclusao.Value := Now;
      tCorpoProcessou.Value := False;
      tCorpoDestino.Value := Email_Cybermgr;
      tCorpoAssunto.Value := 'Cyber Manager - Novo Cadastro';
      SLE.Add('Nova loja testando o Cyber Manager em ' + FormatDateTime('dd/mm/yyyy hh:mm', Now));
      SLE.Add('');
      SLE.Add('Código = ' + FLic.CodLojaAsString);
      SLE.Add('Loja = ' + MT.FieldByName('Loja').AsString);
      SLE.Add('Maquinas = ' + IntToStr(FLic.liMaquinas));
      SLE.Add('Proprietario = ' + MT.FieldByName('Proprietarios').AsString);
      SLE.Add('Gerente = ' + MT.FieldByName('Gerente').AsString);
      SLE.Add('Cidade = ' + MT.FieldByName('Cidade').AsString + '/' + MT.FieldByName('UF').AsString);
      SLE.Add('Telefones = ' + MT.FieldByName('Telefones').AsString);
      SLE.Add('');
      SLE.Add('Email Registro = ' + MT.FieldByname('EmailReg').AsString);
      SLE.Add('');
      SLE.Add('Email Técnico = ' + MT.FieldByname('EmailTec').AsString);
      tCorpoCorpo.Value := SLE.Text;
      tCorpo.Post;

      S := Trim(MT.FieldByName('EmailReg').AsString);
      if Trim(MT.FieldByName('EmailTec').AsString)>'' then
      if S > '' then
        S := S + '; ' + Trim(MT.FieldByName('EmailTec').AsString)
      else
        S := Trim(MT.FieldByName('EmailTec').AsString); 
      
      if (S>'') and FileExists('c:\emailreg.txt') then begin
        SLE.LoadFromFile('c:\emailreg.txt');
        tCorpo.Insert;
        tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
        tCorpoInclusao.Value := Now;
        tCorpoProcessou.Value := False;
        tCorpoDestino.Value := S;
        tCorpoAssunto.Value := 'Cyber Manager';
        tCorpoCorpo.Value := SLE.Text;
        tCorpo.Post;
      end;
    except
    end;
    SLE.Free;
    tCorpo.Active := False;
  finally
    tLog.IndexName := SIndex;
  end;    
end;

procedure TqsRegistro100.OpenDB(aForce: Boolean);
begin
  if (nxSession.ServerEngine=nil) or aForce then 
    start_dbconn(nxSession, aForce);

  if aForce then begin
    tLog.Active := False;
    tAut.Active := False;
    tCli.Active := False;
  end;  
  
  if not tLog.Active then begin   
    tLog.Open;
    tAut.Open;
    tCli.Open;
    tCorpo.Open;
  end;
end;

function TqsRegistro100.ObtemLicenca(
  const Args: array of Variant): Variant;
    {Loja: Integer; Versao: String; SerieHD: String; EmDemo: Boolean}
  
var 
  FLic : TLicenca;
  Str: String;
  AutID : Integer;
begin
  tCli.Active := False;
  tCli.Active := True;
  LI.liHD := '';
  LI.liLoja :=   Args[0];
  AutID := 0;

  if High(Args)>1 then begin
    Str := Args[1];
    LI.liHD := Args[2];
    
    if Args[3]=True then 
      LI.liOper := opModoDemo
    else  
      LI.liOper := opObtemDadosConta;
    LI.liDetalhes.Add('Versăo CM-Server = ' + Args[1]);  
  end;
  
  tAut.IndexName := 'ILoja';
  tCli.IndexName := 'ICodigo';
  if LI.liLoja>0 then begin
    if (not tCli.FindKey([LI.liLoja])) or 
       (tCli.FieldByName('Bloqueado').AsBoolean=True) or
       (not tAut.FindKey([LI.liLoja, True])) or 
       
       Venceu7Dias(tAut) or 
       
       (tAut.FieldByName('Programa').AsInteger<>0) then
    begin
//      LI.liOper := opPirata;
      FLic.Limpa;
      FLic.liMaquinas := 2;
      if (LI.liHD='') and (tCli.FieldByName('Codigo').AsInteger=LI.liLoja) then
        LI.liHD := tCli.FieldByName('SerieHD').AsString;
      FLic.liSerialHD := LI.liHD;
      FLic.liCodLoja := LI.liLoja;
      FLic.liTipo := 4;
      Result := VarArrayOf(['OK', FLic.AsString]);
    end else
    begin
      LeLicencaTab(FLic);
      if not tAut.FieldByName('EnviouCli').AsBoolean then 
        AutID := tAut.FieldByName('ID').AsInteger;
      
      ccInfo_Add(Args[1], LI.liIP, tCli.FieldByName('Codigo').AsInteger, 0 , AutID, False);

      Result := VarArrayOf(['OK', FLic.AsString]);
    end ;
  end else
    Result := VarArrayOf(['OK', '']);
end;

function TqsRegistro100.TrocaHD(const Args: array of Variant): Variant;
var 
  FLic : TLicenca;
  A, B : TCabAutorizacao;
begin
  tCli.Active := False;
  tCli.Active := True;
  LI.liLoja :=   Args[0];
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  if (not tCli.FindKey([Args[0]])) then 
    Result := VarArrayOf(['Loja năo cadastrada na Nextar'])
  else
  if tCli.FieldByName('Senha').AsString<>Args[1] then
    Result := VarArrayOf(['A senha da loja năo está correta'])
  else 
  if tCli.FieldByName('Programa').AsInteger<>0 then
    Result := VarArrayOf(['Software năo licenciado. Sua licença foi transferida para o NexCafé'])
  else begin
    LI.liDetalhes.Add('Serial HD anterior = ' + tCli.FieldByName('SerieHD').AsString);
    LI.liHD := Args[2];

    DebugMsg('TqsRegistro100.TrocaHD - Loja: '+tCli.FieldByName('Codigo').AsString);
    
    A := TCabAutorizacao.Create;
    B := TCabAutorizacao.Create;
    try
      A.Load(LI.liLoja, tCli , tAut);
      B.AssignFrom(A);
      A.caSerieHD := LI.liHD;
      A.Save('cliente', B, tCli, tAut, True);
      if A.CountAtiva>0 then
        LeLicencaTab(FLic) else
        FLic.Limpa;
      Result := VarArrayOf(['OK', FLic.AsString]);
    finally
      A.Free;
      B.Free;
    end;
  end;  
end;

function TqsRegistro100.AtualizaCadastro(
  const Args: array of Variant): Variant;
begin
  Result := VarArrayOf(['É necessário baixar a versăo atual do NexCafé em www.nexcafe.com.br']);
  Exit;

  MT.Active := False;
  MT.Active := True;
  MT.AllData := Args[2];
  tCli.Active := False;
  tCli.Active := True;
  LI.liLoja := Args[0];
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  if (not tCli.FindKey([Args[0]])) then 
    Result := VarArrayOf(['Loja năo cadastrada na Nextar'])
  else
  if tCli.FieldByName('Senha').AsString<>Args[1] then
    Result := VarArrayOf(['A senha da loja năo está correta'])
  else begin
    InitTran(nxDB, [tCli], True);
    try
      tCli.Edit;
      TransfDados(MT, tCli, False);
      tCli.FieldByName('AtualizadoEm').AsDateTime := Now;
      tCli.FieldByName('AtualizadoPor').AsString := 'Cliente';
      tCli.Post;
      nxDB.Commit;
    finally
      if nxDB.InTransaction then nxDB.Rollback;
    end;
    LI.liHD := tCli.FieldByName('SerieHD').AsString;
    Result := VarArrayOf(['OK']);
  end;  
end;

function TqsRegistro100.ObtemCadastro(
  const Args: array of Variant): Variant;
begin
  tCli.Active := True;
  LI.liLoja := Args[0];
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  if (not tCli.FindKey([Args[0]])) then 
    Result := VarArrayOf(['Loja năo cadastrada na Nextar'])
  else
  if tCli.FieldByName('Senha').AsString<>Args[1] then
    Result := VarArrayOf(['A senha da loja năo está correta'])
  else begin
    MT.Active := True;
    MT.Insert;
    TransfDados(tCli, MT, True);
    MT.Post;
    LI.liHD := tCli.FieldByName('SerieHD').AsString;
    Result := VarArrayOf(['OK', MT.AllData]);
  end;  
end;

