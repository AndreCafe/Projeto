function TqsRegistro300.ProcessRequest(const Func: string;
  const ClientIdent: TkbmMWClientIdentity;
  const Args: array of Variant): Variant;
var 
  uFunc, sIP : String;  
begin
  CheckDB;
  Inc(nRequests[1]);


  sIP := ClientIdent.RemoteLocation;
  
  if Pos(':', sIP)>0 then
    Delete(sIP, Pos(':', sIP), 100); 

  uFunc := UpperCase(Func);
  try
    try
      tLog.Active := True;
    except
    end;  
    if uFunc='CRIARCONTA' then begin
      LI.Inicia(opCriarConta, ClientIdent.RemoteLocation);
      Result := CriarConta(Args);
    end else
    if uFunc='CHECACONTA' then begin
      LI.Inicia(opChecaConta, sIP);
      Result := ChecaConta(Args);
    end else  
    if uFunc='TROCAHD' then begin
      LI.Inicia(opTrocaHD, sIP);
      Result := TrocaHD(Args)
    end else  
    if uFunc='UPGRADENEX' then begin
      LI.Inicia(opUpgradeNex, sIP);
      Result := TrocaProg(Args)
    end else  
    if uFunc='ATUALIZADADOSCONTA' then begin
      LI.Inicia(opAtualizaDadosConta, sIP);
      Result := AtualizaDadosConta(Args);
    end else  
    if uFunc='OBTEMDADOSCONTA' then begin
      LI.Inicia(opObtemDadosConta, sIP);
      Result := ObtemDadosConta(Args);
    end else 
    if uFunc='OBTEMCONTAPOREMAIL' then begin
      LI.Inicia(opObtemContaPorEmail, sIP);
      Result := ObtemContaPorEmail(Args);
    end else
    if uFunc='OBTEMCONTAPOREQUIP' then begin
      LI.Inicia(opObtemContaPorEquip, sIP);
      Result := ObtemContaPorEquip(Args);
    end else
    if uFunc='OBTEMSENHA' then begin
      LI.Inicia(opObtemSenha, sIP);
      Result := ObtemSenha(Args);
    end else
    if uFunc='SALVAEST' then begin
      LI.Inicia(opSalvaEst, sIP);
      Result := SalvaEst(Args);
    end else
    if uFunc='ATIVARCONTA' then begin
      LI.Inicia(opAtivarConta, sIP);
      Result := Ativar(Args);
    end else
    if uFunc='OBTEMPARAMASS' then begin
      LI.Inicia(opObtemParamAss, sIP);
      Result := ObtemParamAss(Args);
    end else
    if uFunc='OBTEMDADOSCOBRANCA' then begin
      LI.Inicia(opObtemDadosCobranca, sIP);
      Result := ObtemDadosCobranca(Args);
    end else
    if uFunc='ASSINAR' then begin
      LI.Inicia(opAssinar, sIP);
      Result := Assinar(Args);
    end else
    if uFunc='ALTERARSENHA' then begin
      LI.Inicia(opAlterarSenha, sIP);
      Result := AlterarSenha(Args);
    end else
    if uFunc='CANCELARBOLETO' then begin
      LI.Inicia(opCancelarBoleto, sIP);
      Result := CancelarBoleto(Args);
    end else
    if uFunc='OBTEMBOLETOS' then begin
      LI.Inicia(opObtemBoletos, sIP);
      Result := ObtemBoletos(Args);
    end else
      Result := inherited ProcessRequest(Func, ClientIdent, Args)
  except
    On E: Exception do begin
      DebugMsgEsp('TqsRegistro300.ProcessRequest - uFunc: ' + uFunc + ' - E: ' + E.Message, False, True);
      
      Result := VarArrayOf(['Erro năo esperado no servidor de contas Nextar: ' + E.Message + 
                            sLineBreak+sLineBreak+
                            '. Por favor entre em contato através da opçăo de atendimento online do nosso site: www.nexcafe.com.br']);
    end;
  end;  
  try 
    if Result[0] = 'OK' then
      LI.liOK := True
    else begin 
      LI.liOK := False;
      LI.liDetalhes.Add('RESULTADO = ' + Result[0]);
    end;  
  except
  end;

  if (LI.liLoja>0) and (not tIPLoja.FindKey([sIP, LI.liLoja])) then begin
    if tIPLoja.FindKey([sIP]) then 
      tIPLoja.Edit else
      tIPLoja.Insert;
      
    tIPLojaIP.Value := sIP;
    tIPLojaLoja.Value := LI.liLoja;
    tIPLojaDH.Value := Now;
    tIPLoja.Post;
  end;
  
  if LI.liOper <> opChecaConta then 
    LI.SaveToDataset(tLog);  
end;

