            object cbCheckListBoxAllowedGrayed: TcxCheckBox
              Left = 27
              Top = 80
              Hint = 
                'The AllowGrayed property enables a user to set items into a gray' +
                'ed state.  If AllowGrayed is set to False, items can only be che' +
                'cked or unchecked.  If AllowGrayed is True, items can also be gr' +
                'ayed (i.e. an indeterminate state).'
              Caption = 'Allowed Grayed'
              Properties.OnChange = cbCheckListBoxAllowedGrayedPropertiesChange
              TabOrder = 2
              Width = 123
