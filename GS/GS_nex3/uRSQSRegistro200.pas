  end;
end;

function TqsRegistro200.ObtemLicenca(
  const Args: array of Variant): Variant;
    {Loja: Integer; Versao: String; SerieHD: String; EmDemo: Boolean}
var S: String;  
begin
  tCli.Active := False;
  tCli.Active := True;
  LI.liLoja :=   Args[0];
  
  LI.liHD := Args[2];
  if Args[3]=0 then 
    LI.liOper := opModoDemo
  else  
    LI.liOper := opObtemLicenca;
    
  LI.liDetalhes.Add('Versăo NexServ = ' + Args[1]);  
  
  if LI.liLoja>0 then begin
    if (not tCli.FindKey([LI.liLoja])) or 
       (tCli.FieldByName('Bloqueado').AsBoolean=True) or
       (not tAut.FindKey([LI.liLoja, True])) 
    then  
      Result := VarArrayOf(['OK', LI.liLoja, ChaveBloqueado, ''])
    else
    if tCli.FieldByName('Programa').AsInteger=0 then
      Result := VarArrayOf(['OK', LI.liLoja, ChaveCybermgr, ''])
    else begin
      S := '';
      tAut.IndexName := 'ILoja';
      tAut.SetRange([LI.liLoja, True], [LI.liLoja, True]);
      try
        while not tAut.Eof do begin
          if S>'' then S := S + ';';
          if Venceu7Dias(tAut) then
            S := S + ChaveBloqueado else
            S := S + tAut.FieldByName('Autorizacao').AsString;
          if not tAut.FieldByName('EnviouCli').AsBoolean then begin
            tAut.Edit;
            tAut.FieldByName('EnviouCli').AsBoolean := True;
            tAut.Post;
          end;
          tAut.Next;
        end;
      finally
        tAut.CancelRange;
      end;
      
      tCli.Edit;
      tCli.FieldByName('UObtemLic').AsDateTime := Now;
      tCli.FieldByName('UVersao').AsString := Args[1];
      tCli.Post;
      Result := VarArrayOf(['OK', LI.liLoja, S, tCli.FieldByName('CodEquip').AsString]);
    end ;
  end else
    Result := VarArrayOf(['OK', 0, ChaveBloqueado, '']);
end;

function TqsRegistro200.TrocaHD(const Args: array of Variant): Variant;
var 
  A, B : TCabAutorizacao;
  S: String;
begin
  tCli.Active := False;
  tCli.Active := True;
  LI.liLoja :=   Args[0];
  LI.liDetalhes.Add('Senha = ' + Args[1]);
  if (not tCli.FindKey([Args[0]])) then 
    Result := VarArrayOf(['Loja năo cadastrada na Nextar'])
  else
  if tCli.FieldByName('Senha').AsString<>Args[1] then
    Result := VarArrayOf(['A senha de registro da loja năo está correta'])
  else 
  if tCli.FieldByName('Programa').AsInteger<>1 then
    Result := VarArrayOf(['Software năo licenciado'])
  else begin
    LI.liDetalhes.Add('Serial HD anterior = ' + tCli.FieldByName('SerieHD').AsString);
    LI.liHD := Args[2];
    A := TCabAutorizacao.Create;
    B := TCabAutorizacao.Create;
    try
      A.Load(LI.liLoja, tCli , tAut);
      B.AssignFrom(A);
      A.caCodEquip := LI.liHD;
      A.Save('cliente', B, tCli, tAut);
      S := '';
      tAut.IndexName := 'ILoja';
      tAut.SetRange([LI.liLoja, True], [LI.liLoja, True]);
      try
        while not tAut.Eof do begin
          if S>'' then S := S + ';';
          S := S + tAut.FieldByName('Autorizacao').AsString;
          if not tAut.FieldByName('EnviouCli').AsBoolean then begin
            tAut.Edit;
            tAut.FieldByName('EnviouCli').AsBoolean := True;
            tAut.Post;
          end;
          tAut.Next;
        end;
      finally
        tAut.CancelRange;
      end;
      Result := VarArrayOf(['OK', LI.liLoja, S, A.caCodEquip]);
    finally
      A.Free;
      B.Free;
    end;
  end;  
end;

