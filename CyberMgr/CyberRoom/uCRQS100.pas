     Result:='suporte@cybermgr.com';
end;

{$IFNDEF CPP}class{$ENDIF} function TQS100.GetAssistance:string;
begin
     Result:='suporte@cybermgr.com';
end;

{$IFNDEF CPP}class{$ENDIF} function TQS100.GetDescriptionAbstract:string;
