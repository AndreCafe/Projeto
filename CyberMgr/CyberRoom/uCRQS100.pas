     Result:='VALIDACAO DE USUARIO';
end;

{$IFNDEF CPP}class{$ENDIF} function TQS100.GetFlags:TkbmMWServiceFlags;
begin
     Result:=[mwsfListed];
end;

function TQS100.ProcessRequest(const Func: string;
  const ClientIdent: TkbmMWClientIdentity;
  const Args: array of Variant): Variant;
var 
  uFunc : String;  
begin
  with ClientIdent do begin
    FMA := Copy(ClientLocation, 1, Pos('|', ClientLocation)-1);
    FIP := Copy(ClientLocation, Pos('|', ClientLocation)+1, 50);
  end;  
  
  uFunc := UpperCase(Func);
  if uFunc='KEEPALIVE' then
    Result := KeepAlive(Args)
  else
  if uFunc='USERLOGIN' then
    Result := UserLogin(Args)
  else
  if uFunc='USERLOGOUT' then
    Result := UserLogout(Args)
  else
    Result := inherited ProcessRequest(Func, ClientIdent, Args);
end;

procedure TransfDados(O, D: TDataset; Tudo: Boolean);
var 
  I : Integer;
  F : TField;
begin
  for I := 0 to D.FieldCount-1 do with D.Fields[I] do 
  begin
    F := O.FindField(FieldName);
    if F<>nil then
      Value := F.Value;
  end;  
end;

function TQS100.KeepAlive(const Args: array of Variant): Variant;
begin
  DM.Refresh(GetCurrentThreadID);
end;

function TQS100.UserLogin(const Args: array of Variant): Variant;
var S: String;
begin
  try
    S := Args[0];
    Result := DM.NovaSessao(GetCurrentThreadID, S, qMySql, tSessao, FMA, FIP);
  except
    on E:Exception do 
      Result := E.Message;
  end;      
end;

function TQS100.UserLogout(const Args: array of Variant): Variant;
begin
  try
    DM.FechaSessao(GetCurrentThreadID, qMySql, tSessao, tcUserRequest);
    Result := Null;
  except
    on E:Exception do 
      Result := E.Message;
  end;      
end;

end.






                                            
