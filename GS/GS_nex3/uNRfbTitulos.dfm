  object Q: TnxQuery
    Database = DM.nxDB
    OnCalcFields = QCalcFields
    SQL.Strings = (
      
        'select r.*, c.loja as NomeLoja, c.Bloqueado from receber r, clie' +
        'nte c'
      
        'where (pagamento is null) and (c.codigo = r.loja) and (r.vencime' +
        'nto < DATE '#39'2007-01-09'#39')'
      'order by vencimento')
    Left = 48
    Top = 280
