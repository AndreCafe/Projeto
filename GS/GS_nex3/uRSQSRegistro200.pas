function TqsRegistro200.ObtemCodLojaPorEquip(
  const Args: array of Variant): Variant;
begin
  tCli.Active := False;
  tCli.Active := True;
  tCli.IndexName := 'ICodEquip';
  try
    tCli.SetRange([Args[0]], [Args[0]]);
    try
      if tCli.IsEmpty then
        Result := '' else
        Result := EnviaEmailRegistros(tCli);
      if Result='' then
        Result := VarArrayOf(['']) else
        Result := VarArrayOf(['OK', Result]);
