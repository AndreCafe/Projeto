    tCli.FieldByName('Pais').AsString := Sl.Values['Pais'];
    tCli.FieldByName('Cidade').AsString := sl.Values['Cidade'];
    tCli.FieldByName('UF').AsString := sl.Values['UF'];
    tCli.FieldByName('CodEquip').AsString := SL.Values['CodEquip'];
    tCli.FieldByName('EmailReg').AsString := SL.Values['Email'];
    tCli.FieldByName('EmailConta').AsString := SL.Values['Email'];
    tCli.FieldByName('LicMaq').AsInteger := 1;
    tCli.FieldByName('Senha').AsString := sl.Values['Senha'];
    tCli.FieldByName('CadastroEm').AsDateTime := Now;
    tCli.FieldByName('CadastroPor').AsString := 'Cliente';
    tCli.FieldByName('AtualizadoEm').AsDateTime := Now;
    tCli.FieldByName('AtualizadoPor').AsString := 'Cliente';
    tCli.FieldByName('Programa').AsInteger := 1;
    tCli.FieldByName('Ativado').AsBoolean := False;
    tCli.FieldByName('CodAtivacao').AsString := GeraCodAtivacao;
    tCli.Post;
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
    Reg.CodLoja := LI.liLoja;
    A.Load(tCli.FieldByName('Codigo').AsInteger, tCli, tAut);
    B.AssignFrom(A);
    with A.NewItem do begin
      auTipo := taFreePremium;
      auMaquinas := 1;
      auVencimento := 0;
    end;
    A.Save('cliente', B, tCli, tAut);
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
    LI.liHD := A.caCodEquip;
    tAut.IndexName := 'ILoja';
    if not tAut.FindKey([ LI.liLoja, True]) then
      Result := VarArrayOf(['Falha no servidor de contas Nextar. Por favor faça contato através da opçăo de atendimento online do nosso site: www.nexcafe.com.br']) else
      Result := VarArrayOf(['OK', SL.Values['Email'], ChaveAtivar]);
    SLE := TStringList.Create;
    try
      tCorpo.Active := True;
      S := ExtractFilePath(ParamStr(0)) + 'emailativacao.txt';
      if FileExists(S) then begin
        SLE.LoadFromFile(S);
        S := SLE.Text;

        repeat
          I := Pos('%EMAIL', S);
          if I>0 then
            S := Copy(S, 1, I-1) + tCli.FieldByName('EmailConta').AsString + Copy(S, I+6, Length(S));
        until (I<1);

        repeat
          I := Pos('%CODATIVACAO', S);
          if I>0 then
            S := Copy(S, 1, I-1) + tCli.FieldByName('CodAtivacao').AsString + Copy(S, I+12, Length(S));
        until (I<1);
        
        tCorpo.Insert;
        tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
        tCorpoInclusao.Value := Now;
        tCorpoProcessou.Value := False;
        tCorpoDestino.Value := tCli.FieldByName('EmailConta').AsString;
        tCorpoAssunto.Value := 'NexCafé: Código de Ativaçăo';
        tCorpoCorpo.Value := S;
        tCorpo.Post;
        SLE.Clear;
      end;
      
      tCorpo.Insert;
      tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
      tCorpoInclusao.Value := Now;
      tCorpoProcessou.Value := False;
      tCorpoDestino.Value := TodosNextar;
      tCorpoAssunto.Value := 'NexCafé - Nova Conta!';
      SLE.Add('Conta criada em ' + FormatDateTime('dd/mm/yyyy hh:mm', Now));
      SLE.Add('');
      SLE.Add('Loja = ' + tCli.FieldByName('Loja').AsString);
      SLE.Add('Código = ' + CodLojaToStr(tCli.FieldByName('Codigo').AsInteger));
      SLE.Add('Código de Equipamento = ' + tCli.FieldByName('CodEquip').AsString);
      SLE.Add('Proprietario = ' + tCli.FieldByName('Proprietarios').AsString);
      SLE.Add('Cidade = ' + tCli.FieldByName('Cidade').AsString + '/' + tCli.FieldByName('UF').AsString);
      SLE.Add('');
      SLE.Add('Email = ' + tCli.FieldByname('EmailConta').AsString);
      SLE.Add('Senha = ' + tCli.FieldByName('Senha').AsString);
      SLE.Add('Código de Ativaçăo = ' + tCli.FieldByName('CodAtivacao').AsString);
      tCorpoCorpo.Value := SLE.Text;
      tCorpo.Post;
    except
    end;
    SLE.Free;
    tCorpo.Active := False;
  finally
    SL.Free;
    A.Free;
    B.Free;
  end;    
end;

function TqsRegistro300.ObtemSenha(const Args: array of Variant): Variant;
begin
  Reg.Conta := Args[0];

  tCli.Active := False;
  tCli.Active := True;
  if Reg.CodLoja>0 then begin
    tCli.IndexName := 'ICodigo';
    tCli.SetRange([Args[0]], [Args[0]]);
  end else begin
    tCli.IndexName := 'IEmailConta';
    tCli.SetRange([Reg.Conta], [Reg.Conta]);
  end;
  try
    try
      if not tCli.IsEmpty then
        Result := EnviaEmailRegistros(tCli);
        
      if Result='' then
        Result := VarArrayOf(['']) else
        Result := VarArrayOf(['OK', Result]); 
    finally
      tCli.CancelRange;
    end;
  finally
    tCli.IndexName := 'ICodigo';
  end;
end;

function TqsRegistro300.CancelarBoleto(const Args: array of Variant): Variant;
var N: TDateTime;
begin  
  tCli.Active := False;
  tCli.Active := True;
  tRec.Active := False;
  tRec.Active := True;
  Reg.Conta := Args[0];
  LI.liDetalhes.Add('Conta = ' + Args[0]);
  LI.liDetalhes.Add('Senha = '  +Args[1]);
  LI.liLoja := 0;
  if (Reg.CodLoja=0) and not tCli.Locate('EmailConta', Reg.Conta, []) then
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  if (Reg.CodLoja>0) and not tCli.Locate('Codigo', Reg.CodLoja, []) then
  begin
    Result := VarArrayOf(['Conta inexistente']);
    Exit;
  end;

  LI.liLoja := tCli.FieldByName('Codigo').AsInteger;
  
  if (not SameText(tCli.FieldByName('Senha').AsString, Args[1])) then
  begin
    Result := VarArrayOf(['Senha incorreta']);
    Exit;
  end;

  if not tRec.Locate('ID', Args[2], []) then begin
    Result := VarArrayOf(['Boleto năo encontrado']);
    Exit;
  end;

  if tRecCancelado.Value then begin
    Result := VarArrayOf(['Esse boleto já foi cancelado em ' + FormatDateTime('dd/mm/yyyy', tRecCanceladoEm.Value)]);
    Exit;
  end;

  if tRecLoja.Value <> LI.liLoja then begin
    Result := VarArrayOf(['Esse boleto é de outra loja']);
    Exit;
  end;

  N := Now;
  
  tRec.Edit;
  tRecCancelado.Value := True;
  tRecCanceladoEm.Value := N;
  tRecCanceladoPor.Value := 'cliente';
  tRecPagamento.Value := N;
  tRecBaixou.Value := True;
  tRec.Post;

  Result := VarArrayOf(['OK', N]);
end;

function TqsRegistro300.ChecaConta(
  const Args: array of Variant): Variant;
    {Conta: String; Versao: String; SerieHD: String; EmDemo: Boolean}
var S: String;  
begin
  tCli.Active := False;
  tCli.Active := True;
  Reg.Conta := Args[0];

  if Reg.CodLoja>0 then
    LI.liLoja := Reg.CodLoja
  else 
  if tCli.Locate('EmailConta', Reg.Conta, []) then
    LI.liLoja := tCli.FieldByName('Codigo').AsInteger
  else
    LI.liLoja := 0;    
  
  LI.liOper := opChecaConta;
    
  LI.liDetalhes.Add('Versăo NexServ = ' + Args[1]); 

  tAut.IndexName := 'ILoja'; 
  
  if LI.liLoja>0 then begin
    if (not tCli.FindKey([LI.liLoja])) then
      Result := VarArrayOf(['OK', Reg.Conta, ChaveInexistente, ''])
    else
    if (tCli.FieldByName('Bloqueado').AsBoolean=True) or
       (not tAut.FindKey([LI.liLoja, True])) 
    then  
      Result := VarArrayOf(['OK', Reg.Conta, ChaveBloqueado, ''])
    else
    if tCli.FieldByName('Programa').AsInteger=0 then
      Result := VarArrayOf(['OK', Args[0], ChaveCybermgr, ''])
    else
    if not tCli.FieldByname('Ativado').AsBoolean then
      Result := VarArrayOf(['OK', Reg.Conta, ChaveAtivar, ''])
    else begin
      S := '';
      tAut.IndexName := 'ILoja';
      tAut.SetRange([LI.liLoja, True], [LI.liLoja, True]);
      try
        while not tAut.Eof do begin
          if S>'' then S := S + ';';
          S := S + tAut.FieldByName('Autorizacao').AsString;
          if not tAut.FieldByName('EnviouCli').AsBoolean then begin
            tAut.Edit;
            tAut.FieldByName('EnviouCli').AsBoolean := True;
            tAut.Post;
          end;
          tAut.Next;
        end;
      finally
        tAut.CancelRange;
      end;
      
      tCli.Edit;
      tCli.FieldByName('UObtemLic').AsDateTime := Now;
      tCli.FieldByName('UVersao').AsString := Args[1];
      tCli.Post;
      Result := VarArrayOf(['OK', Args[0], S, ObtemBP(LI.liLoja), ObtemJFP(LI.liLoja)]);
    end ;
  end else
    Result := VarArrayOf(['OK', 0, ChaveInexistente, 0, False]);
end;

