function TqsRegistro200.EnviaEmailRegistros(D: TDataset; aEmail: String = ''): String;
var
  aReg : TStrings;
  aCorpo : String;
  Venc : Variant;
  i2: Integer;
  aRes, aDest : TStrings;

function VariantToDateStr(V: Variant): String;
begin
  if V=null then
    Result := '' else
    Result := FormatDateTime('dd/mm/yyyy', V);
end;

function Expirou(V: Variant): Boolean;
begin
  Result := (V=null) or (Date<V);
end;
  
function NextEmail(var S: String): String;
var P: Integer;
begin
  S := Trim(S);
  Result := '';
  if S>'' then begin
    for P := 1 to Length(S) do
      if Pos(S[P], ' ,;')>0 then begin
        Result := Copy(S, 1, P-1);
        Delete(S, 1, P);
        Exit;
      end;
    Result := S;
    S := '';  
  end;
  if (Pos('@', Result)<1) or (Pos('.', Result)<1) then
    Result := '';
  if (aEmail>'') and  (not SameText(aEmail, Result)) then
    Result := '';
end;

function EmailsValidos: String;
var 
  SL: TStrings;
  S, S2 : String;
  I : Integer;
begin
  Result := '';
  SL := TStringList.Create;
  try
    SL.Text := D.FieldByName('EmailReg').AsString;
    for I := 0 to SL.Count - 1 do begin
      S := SL[I];
      while S>'' do begin 
        S2 := NextEmail(S);
        if S2>'' then begin
          if Result>'' then
            Result := Result+sLineBreak;
          Result := Result + S2;  
        end;
      end;
    end;
  finally
    SL.Free;
  end;
end;  

procedure AddCorpo(S: String);
begin
  aCorpo := aCorpo+S+sLineBreak;
end;

begin
  Result := '';
  aEmail := Trim(aEmail);
  aRes := TStringList.Create;
  aDest := TStringList.Create;
  
  tAut.Active := True;
  tCorpo.Active := True;
  try
    tAut.IndexName := 'ILoja';
    while not D.Eof do begin
      aDest.Text := EmailsValidos;
      if (aDest.Text>'') and tAut.FindKey([D.FieldByName('Codigo').AsInteger, True]) then 
      begin
        for i2 := 0 to aDest.Count-1 do
          if aRes.IndexOf(aDest[i2])=-1 then
            aRes.Add(aDest[i2]);
          
        tCorpo.Insert;
        tCorpoEnviarEm.Value := EncodeDate(2004, 1, 1);
        tCorpoInclusao.Value := Now;
        tCorpoProcessou.Value := False;
        tCorpoDestino.Value := aDest.Text;
        tCorpoAssunto.Value := 'NexCafé - Informaçőes de Registro';
        aCorpo := '';
        AddCorpo('Registro realizado em ' + D.FieldByName('CadastroEm').AsString +':');
        AddCorpo('');
        AddCorpo('Nome da Loja: ' + D.FieldByName('Loja').AsString);
        AddCorpo('Qtd.Máquinas: ' + tAut.FieldByName('Maquinas').AsString);
        AddCorpo('');
        AddCorpo('Cidade: ' + D.FieldByName('Cidade').AsString);
        AddCorpo('Bairro: ' + D.FieldByName('Bairro').AsString);
        AddCorpo('');
        AddCorpo('Codigo de Loja: ' + CodLojaToStr(D.FieldByName('Codigo').AsInteger));
        AddCorpo('Senha de Registro: ' + D.FieldByName('Senha').AsString);
        AddCorpo('');
        Venc := tAut.FieldByName('Vencimento').AsVariant;
        case tAut.FieldByName('Tipo').AsInteger of
          taDefinitiva : AddCorpo('Licença Definitiva: Nunca Expira');
          taLocacao : 
            if Expirou(Venc) then 
              AddCorpo('Locaçăo expirou em: ' + VariantToDateStr(Venc)) else
              AddCorpo('Locaçăo vence em: ' + VariantToDateStr(Venc));

          taTesteGratuito :    
            if Expirou(Venc) then 
              AddCorpo('Licença de Teste Gratuito Expirou em: ' + VariantToDateStr(Venc)) else
              AddCorpo('Licença de Teste Gratuito Expira em: ' + VariantToDateStr(Venc));

          taTemporaria :    
            if Expirou(Venc) then 
              AddCorpo('Licença Temporária Expirou em: ' + VariantToDateStr(Venc)) else
              AddCorpo('Licença Temporária Expira em: ' + VariantToDateStr(Venc));
        end;
        tCorpoCorpo.Value := aCorpo;
        
        tCorpo.Post;
      end;
      D.Next;
    end;
    Result := aRes.Text;
  finally
    aRes.Free;
    aDest.Free;
  end;
end;

