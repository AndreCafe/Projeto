  LI := TLogInfo.Create;
end;

procedure TqsRegistro100.kbmMWQueryServiceDestroy(Sender: TObject);
begin
  LI.Free;
end;

function TqsRegistro100.LogModoDemo(const Args: array of Variant): Variant;
var S : String;
begin
  S := Args[0];
  LI.liHD := S;
  Result := VarArrayOf(['OK']);
end;

end.






                                            
