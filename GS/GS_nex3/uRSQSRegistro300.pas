begin
  Result := SalvaEstInt(Args[0], Args[1], Args[2], Args[3], Args[4], Args[5], Args[6], Args[7], Args[8]);
end;

function TqsRegistro300.SalvaEstInt(aConta: String; aCodEquip: String;
  aData: TDateTime; aCaixa, aURLs, aQtdSessoes: Integer; aTempoSessoes: Double;
  aRes, aSearch: String): Boolean;
var 
  Achou : Boolean; 
  SL : TStrings; 
  I: Integer;
  aCodLoja : Integer;
  cTipo : Char;
  sEng: String;
begin
  InitTran(nxDB, [tCli, tEst, tEstSearch, tEstRes], True);
  try
    tEstSearch.IndexName := 'IEstEng';
    Reg.Conta := aConta;
    if Reg.CodLoja>0 then
      aCodLoja := Reg.CodLoja
    else 
    if (Trim(aConta)>'') and tCli.Locate('EmailConta', aConta, []) then
      aCodLoja := tCli.FieldByName('Codigo').AsInteger else
      aCodLoja := 0;
      
    if aCodLoja>0 then begin
      tEst.IndexName := 'ILojaCaixa';
      Achou := tEst.FindKey([aCodLoja, aCaixa]);
    end else begin
      tEst.IndexName := 'ICodEquipCaixa';
      Achou := tEst.FindKey([aCodEquip, aCaixa]);
    end;
    if Achou then begin
      while tEstSearch.FindKey([tEstID.Value]) do tEstSearch.Delete;
      if aCodLoja>0 then begin
        tEstRes.IndexName := 'ILojaRes';
        while tEstRes.FindKey([aCodLoja]) do tEstRes.Delete;
      end else begin
        tEstRes.IndexName := 'ICodEquipRes';
        while tEstRes.FindKey([aCodEquip]) do tEstRes.Delete;
      end;
      tEst.Edit;
    end else 
      tEst.Insert;
    tEstLoja.Value := aCodLoja;
    tEstCodEquip.Value := aCodEquip;
    tEstData.Value := aData;
    tEstCaixa.Value := aCaixa;
    tEstURLs.Value := aURLs;
    tEstSessoesQtd.Value := aQtdSessoes;
    tEstSessoesTempo.Value := aTempoSessoes;  
    tEstDataAtu.Value := Now;
    tEst.Post;
    SL := TStringList.Create;
    try
      SL.Text := aRes;
      for I := 0 to SL.Count - 1 do begin
        tEstRes.Insert;
        tEstResLoja.Value := aCodLoja;
        tEstResCodEquip.Value := aCodEquip;
        tEstResRes.Value := SL.Names[I];
        tEstResQtd.Value := StrToIntDef(SL.ValueFromIndex[I], 0);
        tEstRes.Post;
      end;
  
      SL.Text := aSearch;
      for I := 0 to SL.Count - 1 do begin
        sEng := SL.Names[I];
        if sEng>'' then
          cTipo := sEng[1] else
          cTipo := #0;
        Delete(sEng, 1, 2);
        
        if (sEng>'') and (cTipo<>#0) then begin
          if tEstSearch.FindKey([tEstID.Value, sEng]) then
            tEstSearch.Edit else
            tEstSearch.Insert;
          tEstSearchEng.Value := sEng;
          tEstSearchLoja.Value := aCodLoja;
          tEstSearchCodEquip.Value := aCodEquip;
          tEstSearchData.Value := aData;
          tEstSearchCaixa.Value := aCaixa;
          tEstSearchEst.Value := tEstID.Value;
          tEstSearchDataAtu.Value := tEstDataAtu.Value;
          case cTipo of
            'q' : tEstSearchQtd.Value := StrToIntDef(SL.ValueFromIndex[I], 0);
            'p' : tEstSearchPag.Value := StrToIntDef(SL.ValueFromIndex[I], 0);
          end;
          tEstSearch.Post;
        end;
      end;
    finally
      SL.Free;
    end;
    nxDB.Commit;
  except
    nxDB.Rollback;
    Raise;
  end;
  Result := True;
end;

procedure TransfDados(O, D: TDataset; Tudo: Boolean);
var 
  I : Integer;
  F : TField;
begin
  for I := 0 to D.FieldCount-1 do with D.Fields[I] do 
  if Tudo or ((DataType<>ftAutoInc) and (Pos('|'+UpperCase(FieldName)+'|', CamposReadOnly)=0)) then 
  begin
    F := O.FindField(FieldName);
    if F<>nil then
      Value := F.Value;
  end;  
end;

function GeraCodAtivacao: String;
var 
  I : Integer;
  S : String;
begin
  S := IntToStr(Random(9999999));
  Result := '';
  for I := 1 to Length(S) do
    Result := S[I] + Result;
  while Length(Result)<7 do
    Result := Result + IntToStr(Random(9)); 
end;

function TqsRegistro300.CriarConta(
  const Args: array of Variant): Variant;
var 
  SIndex : String;
  SLE : TStrings;
  S : String;
  Dia : TDateTime;
  A, B: TCabAutorizacao;
  I: Integer;
  SL: TStringList;
begin
