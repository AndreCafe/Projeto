            object cbColorComboDefaultColorStyle: TcxComboBox
              Left = 161
              Top = 103
              Hint = 
                'Color combo box controls do not insist that a color is selected.' +
                '  By default, no color is selected at application startup for in' +
                'stance.  End users can also force the editor to accept this stat' +
                'e by pressing the ESC key. '
              Properties.OnEditValueChanged = cbColorComboDefaultColorStylePropertiesEditValueChanged
              TabOrder = 3
              Width = 121
            end
            object cbColorComboNamingConvention: TcxComboBox
              Left = 161
              Top = 26
              Hint = 
                'Basically, the NamingConvention property specifies the correspon' +
                'dence between colors and their text descriptions.  If the curren' +
                't naming convention includes a color, this color'#8217's description i' +
                's displayed within the item.  Otherwise, the RGB representation ' +
                'of the color is displayed. '
              Properties.OnEditValueChanged = cbColorComboNamingConventionPropertiesEditValueChanged
              TabOrder = 0
              Width = 121
            end
            object cbColorComboShowDescription: TcxCheckBox
              Left = 27
              Top = 153
              Hint = 
                'Set the ShowDescriptions property to False to hide text descript' +
                'ions displayed within items.  If it is set to True, descriptions' +
                ' are displayed.  '
              Caption = 'Show Description'
              Properties.OnChange = cbColorComboShowDescriptionPropertiesEditValueChanged
              TabOrder = 4
              Width = 131
            end
            object cbColorComboBoxColorValueFormat: TcxComboBox
              Left = 161
              Top = 51
              Hint = 
                'Specifies the format of descriptions for colors not recognized b' +
                'y the current naming convention.'
              Properties.OnEditValueChanged = cbColorComboBoxColorValueFormatPropertiesEditValueChanged
              TabOrder = 1
              Width = 121
            end
            object cbColorComboBoxColorBoxAlign: TcxComboBox
