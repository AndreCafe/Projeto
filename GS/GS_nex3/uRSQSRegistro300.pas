    SL.Text := Args[0];
    if tCli.Locate('EmailConta', SL.Values['Email'], []) then begin
      Result := VarArrayOf(['Já existe uma conta com o e-mail "' + SL.Values['Email'] + 
                            '". É necessário um e-mail diferente para cada loja.']);         
      Exit;
    end;     
      
    tCli.Active := False;
    tCli.Active := True;
