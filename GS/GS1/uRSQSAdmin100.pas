class function TqsAdmin100.GetVersion: string;
begin
     Result:='100';
end;

function TqsAdmin100.ProcessRequest(const Func: string;
  const ClientIdent: TkbmMWClientIdentity;
  const Args: array of Variant): Variant;
var AFunc: String;
begin
  AFunc := Trim(UpperCase(Func));
  if AFunc='GETNEXTAUTOINC' then
    Result := GetNextAutoInc(Args[0], Args[1], Args[2])
  else  
  if AFunc='LOGIN' then
    Result := Result
  else  
  if AFunc='ALTERASENHA' then
    AlteraSenha(Args[0], Args[1])
  else 
    Result:= inherited ProcessRequest(Func, ClientIdent, Args);
end;

procedure TqsAdmin100.ResolverInsert(Sender: TkbmMWCustomResolver;
  var Skip, Abort: Boolean);
begin
  Inc(Contador);
end;

procedure TqsAdmin100.kbmMWQueryServiceAuthenticate(Sender: TObject;
  ClientIdent: TkbmMWClientIdentity; var Perm: TkbmMWAccessPermissions);
const
  BoolSN : Array[Boolean] of Char = ('N', 'S');  
var
  ThID: Cardinal;
begin
  ThID := ThreadID;
  with ClientIdent do 
  if (Token>'') and (Copy(Token, 7, 20)=IntToStr(ThID)) then
    Perm := [mwapRead,mwapWrite,mwapDelete,mwapExecute]
  else begin
    tUsuario.Active := True;
    tUsuario.IndexName := 'IUsername';
    if not tUsuario.FindKey([Username]) then 
      Raise Exception.Create('O Nome de usu·rio '+Username+' n„o existe.');

    if tUsuarioSenha.Value <> Password then 
      Raise Exception.Create('Senha inv·lida');

    Token := 'ADMIN'+BoolSN[tUsuarioAdmin.Value]+IntToStr(ThID);
    Perm := [mwapRead,mwapWrite,mwapDelete,mwapExecute];
  end;
end;

function TqsAdmin100.ThreadID: Cardinal;
begin
//  Result := GetCurrentThreadID;
  Result := TidPeerThread(TkbmMWServerTransportInfo(RequestTransportStream.Info).Client).ThreadID;
end;

procedure TqsAdmin100.kbmMWQueryServiceCreate(Sender: TObject);
begin
  nxTCPIP.ServerName := DBServer;
  nxSession.Active := True;
  nxDB.Connected := True;
  tUsuario.Active := True;
end;

procedure TqsAdmin100.kbmMWQueryServiceAuthenticateQuery(Sender: TObject;
  Query: TkbmMWCustomPooledCursor; ClientIdent: TkbmMWClientIdentity;
  var Permissions: TkbmMWAccessPermissions);
begin
  Permissions := [mwapRead,mwapWrite,mwapDelete,mwapExecute];
end;

procedure TqsAdmin100.AlteraSenha(AUsername, ASenha: String);
begin
  if not tUsuario.FindKey([AUsername]) then
    Raise Exception.Create('O Nome de usu·rio ' + AUsername + 'n„o existe!');
  InitTran(nxDB, [tUsuario], True);
  try  
    tUsuario.Edit;
    tUsuarioSenha.Value := ASenha;
    tUsuario.Post;
    nxDB.Commit;
  except
    nxDB.Rollback;
    Raise;
  end;  
end;

