[Setup]
AppName=NexCafť NexServ
AppVerName=NexServ 3.0.0.91
AppPublisherURL=http://www.nexcafe.com.br
AppSupportURL=http://www.nexcafe.com.br
AppUpdatesURL=http://www.nexcafe.com.br
DefaultDirName=C:\nexcafe
DefaultGroupName=NexCafť
OutputDir=c:\meus programas\nexcafe
OutputBaseFilename=setup_nexserv2

[Tasks]
; NOTE: The following entry contains English phrases ("Create a desktop icon" and "Additional icons"). You are free to translate them into another language if required.
Name: desktopicon; Description: Criar um Ūcone no &desktop; GroupDescription: Õcones adicionais:
; NOTE: The following entry contains English phrases ("Create a Quick Launch icon" and "Additional icons"). You are free to translate them into another language if required.
; Name: "quicklaunchicon"; Description: "Create a &Quick Launch icon"; GroupDescription: "Õcones adicionais:"; Flags: unchecked
Name: autostarticon; Description: Executar o NexServ automaticamente ao iniciar Windows; GroupDescription: Õcones adicionais:

[Files]
Source: C:\Meus Programas\nexcafe\NexServ.exe; DestDir: {app}; Flags: ignoreversion
Source: C:\meus programas\nexcafe\nexguard.exe; DestDir: {app}\Atualiza; Flags: ignoreversion
; NOTE: Don't use "Flags: ignoreversion" on any shared system files


[INI]
Filename: {app}\NexServ.url; Section: InternetShortcut; Key: URL; String: http://www.nexcafe.com.br

[Icons]
Name: {group}\NexCafť NexServ; Filename: {app}\NexServ.exe; WorkingDir: {app}
Name: {group}\Suporte Tťcnico NexCafť; Filename: {app}\suporte\CallingCard.exe; WorkingDir: {app}\suporte; IconIndex: 0
Name: {userdesktop}\Suporte Tťcnico NexCafť; Filename: {app}\suporte\CallingCard.exe; WorkingDir: {app}\suporte; IconIndex: 0
Name: {group}\Desinstalar NexCafť NexServ; Filename: {uninstallexe}
Name: {userdesktop}\NexCafť NexServ; Filename: {app}\NexServ.exe; Tasks: desktopicon; WorkingDir: {app}
;Name: "{userappdata}\Microsoft\Internet Explorer\Quick Launch\NexCafť NexServ"; Filename: "{app}\NexServ.exe"; Tasks: quicklaunchicon
Name: {commonstartup}\NexCafť NexServ; Filename: {app}\NexServ.exe; Tasks: autostarticon; WorkingDir: {app}
Name: {group}\{cm:UninstallProgram, NexCafť NexServ}; Filename: {uninstallexe}

[Run]
; NOTE: The following entry contains an English phrase ("Launch"). You are free to translate it into another language if required.
Filename: {app}\NexServ.exe; Description: Executar o NexCafť NexServ; Flags: nowait postinstall skipifsilent

[UninstallDelete]
Type: files; Name: {app}\NexServ.url

[Languages]
Name: Portugues; MessagesFile: compiler:Languages\BrazilianPortuguese.isl

