package ncD10;

{$R *.res}
{$ALIGN 8}
{$ASSERTIONS ON}
{$BOOLEVAL OFF}
{$DEBUGINFO ON}
{$EXTENDEDSYNTAX ON}
{$IMPORTEDDATA ON}
{$IOCHECKS ON}
{$LOCALSYMBOLS ON}
{$LONGSTRINGS ON}
{$OPENSTRINGS ON}
{$OPTIMIZATION ON}
{$OVERFLOWCHECKS OFF}
{$RANGECHECKS OFF}
{$REFERENCEINFO ON}
{$SAFEDIVIDE OFF}
{$STACKFRAMES OFF}
{$TYPEDADDRESS OFF}
{$VARSTRINGCHECKS ON}
{$WRITEABLECONST ON}
{$MINENUMSIZE 1}
{$IMAGEBASE $400000}
{$DESCRIPTION 'NexCafe'}
{$IMPLICITBUILD OFF}

requires
  vcl,
  vcldb,
  vclx,
  HDSerialD10,
  dcllmd_d2006,
  kbmMemD2006Run,
  kbmMWRunD2006,
  rtl,
  dbrtl,
  dclstd,
  designide,
  xmlrtl,
  vclactnband,
  vcldesigner,
  dcldb,
  bdertl,
  dclIndy10,
  NextarCSCommD10,
  vcljpg,
  fs10,
  frx10,
  frxDB10,
  frxe10,
  cxLibraryD10,
  dxThemeD10,
  cxEditorsD10,
  cxDataD10,
  cxExtEditorsD10,
  NexusDB108sq90,
  NexusDB108re90,
  NexusDB108pt90,
  NexusDB108tw90,
  NexusDB108ch90;

contains
  ncServBase in 'ncServBase.pas',
  ncServBD in 'ncServBD.pas' {FFEM: TnxBaseEngineManager},
  ncServCom in 'ncServCom.pas',
  ncServReg in 'ncServReg.pas',
  ncCompCliente in 'ncCompCliente.pas',
  ncClassesBase in 'ncClassesBase.pas',
  ncServRemoto in 'ncServRemoto.pas',
  ncNetMsg in 'ncNetMsg.pas',
  ncTarifador in 'ncTarifador.pas',
  ncAuxPassaporte in 'ncAuxPassaporte.pas',
  ncTran in 'ncTran.pas',
  ncDMServ in 'ncDMServ.pas',
  ncPassaportes in 'ncPassaportes.pas',
  ncSessao in 'ncSessao.pas',
  ncMovEst in 'ncMovEst.pas',
  ncErros in 'ncErros.pas',
  ncItemTran in 'ncItemTran.pas',
  ncCredTempo in 'ncCredTempo.pas',
  ncImpressao in 'ncImpressao.pas',
  ncDebito in 'ncDebito.pas',
  ncDMCaixa in 'ncDMCaixa.pas',
  ncIDRecursos in 'ncIDRecursos.pas',
  ncListaID in 'ncListaID.pas',
  ncMsgCom in 'ncMsgCom.pas',
  ncServAtualizaLic in 'ncServAtualizaLic.pas',
  ncDebug in 'ncDebug.pas',
  ncEstruturaTabs in 'ncEstruturaTabs.pas';

end.
